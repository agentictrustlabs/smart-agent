@prefix sa:    <https://smartagent.io/ontology/core#> .
@prefix sar:   <https://smartagent.io/ontology/relationships#> .
@prefix sat:   <https://smartagent.io/ontology/trust#> .
@prefix atl:   <https://agentictrust.io/ontology/core#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix p-plan: <http://purl.org/net/p-plan#> .
@prefix dul:   <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .

# =============================================================================
# Smart Agent Trust Model  (T-Box)
# =============================================================================
#
# PROV-native DnS (Descriptions and Situations) trust primitives.
# Mirrors the legacy ATL trust.ttl pattern: Situations reify contexts,
# Assertions are epistemically neutral content, AttestationActs produce
# durable AttestedAssertion records with provenance.
#
# Version: 0.1.0
# =============================================================================

<https://smartagent.io/ontology/trust>
    a owl:Ontology ;
    rdfs:label "Smart Agent Trust Model" ;
    rdfs:comment "T-Box: DnS trust primitives -- Situations, Assertions, Attestations." ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://smartagent.io/ontology/core> ,
                <https://smartagent.io/ontology/relationships> .


# =============================================================================
# DnS Core Primitives (DOLCE-aligned, PROV-native)
# =============================================================================

sat:Situation
    a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Situation" ;
    rdfs:comment "Epistemic/social context in which entities play roles and relations hold. Modeled as a PROV Entity." ;
    owl:equivalentClass atl:Situation .

sat:SituationDescription
    a owl:Class ;
    rdfs:subClassOf prov:Plan , p-plan:Plan ;
    rdfs:label "Situation Description" ;
    rdfs:comment "Conceptual schema defining roles/constraints/meaning for a Situation." ;
    owl:equivalentClass atl:SituationDescription .

sat:Assertion
    a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Assertion" ;
    rdfs:comment "Epistemically neutral asserted content object." ;
    owl:equivalentClass atl:Assertion .

sat:AttestedAssertion
    a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Attested Assertion" ;
    rdfs:comment "Durable, attributable assertion artifact generated by an Attestation activity." ;
    owl:equivalentClass atl:AttestedAssertion .

sat:AssertionAct
    a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Assertion Act" ;
    rdfs:comment "Time-scoped act of asserting." ;
    owl:equivalentClass atl:AssertionAct .

sat:Attestation
    a owl:Class ;
    rdfs:subClassOf sat:AssertionAct ;
    rdfs:label "Attestation" ;
    rdfs:comment "Accountable act that attests an Assertion (prov:used) and produces an AttestedAssertion (prov:generated)." ;
    owl:equivalentClass atl:Attestation .

sat:Role
    a owl:Class ;
    rdfs:subClassOf prov:Entity , p-plan:Role ;
    rdfs:label "Role" ;
    rdfs:comment "Context-dependent role within a Situation." ;
    owl:equivalentClass atl:Role .

sat:SituationParticipation
    a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Situation Participation" ;
    rdfs:comment "Reified link between a Situation and a participating Agent, qualified by a Role." .


# =============================================================================
# DnS Linking Properties
# =============================================================================

sat:hasSituationDescription  a owl:ObjectProperty ; rdfs:label "has situation description"  ; rdfs:domain sat:Situation    ; rdfs:range sat:SituationDescription .
sat:hasRole                  a owl:ObjectProperty ; rdfs:label "has role"                   ; rdfs:domain sat:Situation    ; rdfs:range sat:Role .
sat:rolePlayer               a owl:ObjectProperty ; rdfs:label "role player"                ; rdfs:domain sat:Role         ; rdfs:range prov:Agent .
sat:assertsSituation         a owl:ObjectProperty ; rdfs:label "asserts situation"           ; rdfs:domain sat:AssertionAct ; rdfs:range sat:Situation .
sat:recordsSituation         a owl:ObjectProperty ; rdfs:label "records situation"           ; rdfs:domain sat:AttestedAssertion ; rdfs:range sat:Situation .
sat:isAboutAgent             a owl:ObjectProperty ; rdfs:subPropertyOf prov:wasAttributedTo ; rdfs:label "is about agent"  ; rdfs:domain sat:Situation ; rdfs:range prov:Agent .
sat:assertedBy               a owl:ObjectProperty ; rdfs:subPropertyOf prov:wasAssociatedWith ; rdfs:label "asserted by"   ; rdfs:domain sat:AssertionAct ; rdfs:range prov:Agent .
sat:generatedAssertionRecord a owl:ObjectProperty ; rdfs:subPropertyOf prov:generated        ; rdfs:label "generated assertion record" ; rdfs:domain sat:AssertionAct ; rdfs:range sat:AttestedAssertion .


# =============================================================================
# Trust Specializations
# =============================================================================

sat:TrustSituation              a owl:Class ; rdfs:subClassOf sat:Situation              ; rdfs:label "Trust Situation" .
sat:VerificationTrustSituation  a owl:Class ; rdfs:subClassOf sat:TrustSituation         ; rdfs:label "Verification Trust Situation" .
sat:ReputationTrustSituation    a owl:Class ; rdfs:subClassOf sat:TrustSituation         ; rdfs:label "Reputation Trust Situation" .
sat:DelegationTrustSituation    a owl:Class ; rdfs:subClassOf sat:TrustSituation         ; rdfs:label "Delegation Trust Situation" .
sat:RelationshipTrustSituation  a owl:Class ; rdfs:subClassOf sat:TrustSituation         ; rdfs:label "Relationship Trust Situation" .

sat:TrustAssertion              a owl:Class ; rdfs:subClassOf sat:AttestedAssertion       ; rdfs:label "Trust Assertion" .
sat:VerificationTrustAssertion  a owl:Class ; rdfs:subClassOf sat:TrustAssertion          ; rdfs:label "Verification Trust Assertion" .
sat:ReputationTrustAssertion    a owl:Class ; rdfs:subClassOf sat:TrustAssertion          ; rdfs:label "Reputation Trust Assertion" .
sat:DelegationTrustAssertion    a owl:Class ; rdfs:subClassOf sat:TrustAssertion          ; rdfs:label "Delegation Trust Assertion" .
sat:RelationshipTrustAssertion  a owl:Class ; rdfs:subClassOf sat:TrustAssertion          ; rdfs:label "Relationship Trust Assertion" .

sat:TrustAssertionAct              a owl:Class ; rdfs:subClassOf sat:Attestation           ; rdfs:label "Trust Assertion Act" .
sat:VerificationTrustAssertionAct  a owl:Class ; rdfs:subClassOf sat:TrustAssertionAct    ; rdfs:label "Verification Trust Assertion Act" .
sat:ReputationTrustAssertionAct    a owl:Class ; rdfs:subClassOf sat:TrustAssertionAct    ; rdfs:label "Reputation Trust Assertion Act" .
sat:DelegationTrustAssertionAct    a owl:Class ; rdfs:subClassOf sat:TrustAssertionAct    ; rdfs:label "Delegation Trust Assertion Act" .
sat:RelationshipTrustAssertionAct  a owl:Class ; rdfs:subClassOf sat:TrustAssertionAct    ; rdfs:label "Relationship Trust Assertion Act" .

sat:hasTrustScore   a owl:DatatypeProperty ; rdfs:label "has trust score"   ; rdfs:domain sat:TrustAssertion ; rdfs:range xsd:decimal .
sat:hasTrustAssertion a owl:ObjectProperty ; rdfs:label "has trust assertion" ; rdfs:domain prov:Agent ; rdfs:range sat:TrustAssertion .


# =============================================================================
# Materialized Assertion Summaries (for fast query)
# =============================================================================

sat:AssertionSummary
    a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Assertion Summary" ;
    rdfs:comment "Materialized aggregate summary of assertions for an agent." .

sat:assertionCount      a owl:DatatypeProperty ; rdfs:label "assertion count"     ; rdfs:domain sat:AssertionSummary ; rdfs:range xsd:integer .
sat:lastAssertionTime   a owl:DatatypeProperty ; rdfs:label "last assertion time" ; rdfs:domain sat:AssertionSummary ; rdfs:range xsd:integer .
sat:hasAssertionSummary a owl:ObjectProperty   ; rdfs:label "has assertion summary" ; rdfs:domain sa:Agent ; rdfs:range sat:AssertionSummary .


# =============================================================================
# Delegation Trust (DnS-modeled)
# =============================================================================

sat:DelegationPermission  a owl:Class ; rdfs:subClassOf prov:Entity ; rdfs:label "Delegation Permission" .
sat:DelegationCaveat      a owl:Class ; rdfs:subClassOf prov:Entity ; rdfs:label "Delegation Caveat" .
sat:CaveatEnforcer        a owl:Class ; rdfs:subClassOf prov:Entity ; rdfs:label "Caveat Enforcer" .

sat:delegationDelegator        a owl:ObjectProperty   ; rdfs:label "delegation delegator"        ; rdfs:domain sat:DelegationTrustSituation ; rdfs:range prov:Agent .
sat:delegationDelegatee        a owl:ObjectProperty   ; rdfs:label "delegation delegatee"        ; rdfs:domain sat:DelegationTrustSituation ; rdfs:range prov:Agent .
sat:delegationGrantsPermission a owl:ObjectProperty   ; rdfs:label "delegation grants permission" ; rdfs:domain sat:DelegationTrustSituation ; rdfs:range sat:DelegationPermission .
sat:delegationHasCaveat        a owl:ObjectProperty   ; rdfs:label "delegation has caveat"        ; rdfs:domain sat:DelegationTrustSituation ; rdfs:range sat:DelegationCaveat .
sat:delegationExpiresAtTime    a owl:DatatypeProperty ; rdfs:label "delegation expires at time"   ; rdfs:domain sat:DelegationTrustSituation ; rdfs:range xsd:dateTime .

# =============================================================================
# Relationship Trust (DnS-modeled)
# =============================================================================

sat:Relationship          a owl:Class ; rdfs:subClassOf prov:Entity ; rdfs:label "Relationship" ; rdfs:comment "A trust-qualified relationship between agents." .
sat:assertsRelationship   a owl:ObjectProperty ; rdfs:label "asserts relationship"   ; rdfs:domain sat:RelationshipTrustAssertion ; rdfs:range sat:Relationship .
sat:hasRelationship       a owl:ObjectProperty ; rdfs:label "has relationship"       ; rdfs:domain prov:Agent ; rdfs:range sat:Relationship .
