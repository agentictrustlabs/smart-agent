@prefix sa:        <https://smartagent.io/ontology/core#> .
@prefix saint:     <https://smartagent.io/ontology/intent#> .
@prefix samatch:   <https://smartagent.io/ontology/match#> .
@prefix saneed:    <https://smartagent.io/ontology/need#> .
@prefix saoffer:   <https://smartagent.io/ontology/offering#> .
@prefix sawq:      <https://smartagent.io/ontology/work-queue#> .
@prefix sageo:     <https://smartagent.io/ontology/geo#> .
@prefix hub:       <https://smartagent.io/ontology/hub-marketplace#> .
@prefix skos:      <http://www.w3.org/2004/02/skos/core#> .
@prefix dul:       <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix prov:      <http://www.w3.org/ns/prov#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# Smart Agent Match + Discover + Fulfillment Ontology  (T-Box)
# =============================================================================
#
# The bridge between Need and Resource. The agent-team review stressed
# that NeedResourceMatch is the most important addition to the model:
# first-class object for search results, recommendations, explanations,
# workflow handoff, approvals, and audit history.
#
# Discover → generates matches.
# Fulfillment → consumes matches and the offerings they reference.

<https://smartagent.io/ontology/match> a owl:Ontology ;
    rdfs:label "Smart Agent Match / Discover / Fulfillment Ontology" ;
    rdfs:comment "Bridge between Need and Resource. Discover generates Matches; matches turn into WorkItems; WorkItems trigger Activities; Activities fulfill Needs." ;
    owl:versionInfo "v0" ;
    owl:imports <https://smartagent.io/ontology/core> ,
                <https://smartagent.io/ontology/need> ,
                <https://smartagent.io/ontology/offering> ,
                <http://www.w3.org/ns/prov-o> .

# ─── Top classes ─────────────────────────────────────────────────────

samatch:NeedResourceMatch a owl:Class ;
    rdfs:subClassOf dul:Situation , prov:Entity ;
    rdfs:label "Need-Resource Match" ;
    rdfs:comment "A proposed, accepted, rejected, or stale fit between a NeedOccurrence and a ResourceOffering. Carries a score, a reason, a list of satisfied/missed requirements, and a generatedBy pointer to the DiscoverActivity." .

samatch:DiscoverActivity a owl:Class ;
    rdfs:subClassOf prov:Activity , dul:Action ;
    rdfs:label "Discover Activity" ;
    rdfs:comment "The activity that generated a set of matches. prov:used the NeedOccurrence(s) and ResourceOffering(s) it considered; prov:generated the NeedResourceMatch records." .

samatch:FulfillmentActivity a owl:Class ;
    rdfs:subClassOf prov:Activity , dul:Action ;
    rdfs:label "Fulfillment Activity" ;
    rdfs:comment "What actually happens to address the need. Distinct from DiscoverActivity: discover proposes, fulfillment acts. Carries fulfillsNeed + usesResource." .

samatch:RoleAssignment a owl:Class ;
    rdfs:subClassOf dul:Situation , prov:Entity ;
    rdfs:label "Role Assignment" ;
    rdfs:comment "Time-bound situational role-play. Replaces 'Kenji a role:Coach' globally. Use roleBearer + rolePlayed + roleContext + roleTarget + status." .

# ─── Match properties ────────────────────────────────────────────────

samatch:matchesNeed a owl:ObjectProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  saneed:NeedOccurrence .

samatch:matchedOffering a owl:ObjectProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  saoffer:ResourceOffering .

samatch:matchedResource a owl:ObjectProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  saoffer:Resource .

samatch:matchedAgent a owl:ObjectProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  sa:Agent .

samatch:satisfiesRequirement a owl:ObjectProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  saneed:Requirement ;
    rdfs:comment "Requirement IDs the offering satisfies. Drives the 'why does this fit?' explanation." .

samatch:missesRequirement a owl:ObjectProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  saneed:Requirement ;
    rdfs:comment "Requirement IDs the offering does NOT satisfy. Drives the 'what's missing?' explanation." .

samatch:matchScore a owl:DatatypeProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  xsd:decimal ;
    rdfs:comment "0..10000 basis points. <2000 not surfaced; <4000 not in default ranked list." .

samatch:matchReason a owl:ObjectProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  skos:Concept .   # SkillRoleGeoFit | TrustGraphProximity | CredentialMatch | …

samatch:matchStatus a owl:ObjectProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  skos:Concept .   # Proposed | Accepted | Rejected | Stale | Fulfilled

samatch:matchGeneratedBy a owl:ObjectProperty ;
    rdfs:domain samatch:NeedResourceMatch ;
    rdfs:range  samatch:DiscoverActivity .

# ─── Fulfillment properties ──────────────────────────────────────────

samatch:fulfillsNeed a owl:ObjectProperty ;
    rdfs:domain prov:Activity ;
    rdfs:range  saneed:NeedOccurrence ;
    rdfs:comment "Activity → Need. Closes the PROV chain: discover→match→fulfill→outcome." .

samatch:usesResource a owl:ObjectProperty ;
    rdfs:domain prov:Activity ;
    rdfs:range  saoffer:ResourceOffering ;
    rdfs:comment "Activity → Offering. Use prov:used as the underlying property; this is the typed alias." .

samatch:assignedTo a owl:ObjectProperty ;
    rdfs:range sa:Agent .

samatch:forWorkMode a owl:ObjectProperty ;
    rdfs:range sawq:WorkMode .

samatch:triggeredBy a owl:ObjectProperty ;
    rdfs:range prov:Entity .   # NeedOccurrence | Match | Event

samatch:suggestsTask a owl:ObjectProperty ;
    rdfs:range sa:Task .

samatch:producedOutcome a owl:ObjectProperty ;
    rdfs:range sa:Outcome .

# ─── Role assignment properties ──────────────────────────────────────

samatch:roleBearer a owl:ObjectProperty ;
    rdfs:domain samatch:RoleAssignment ;
    rdfs:range  sa:Agent .

samatch:rolePlayed a owl:ObjectProperty ;
    rdfs:domain samatch:RoleAssignment .

samatch:roleContext a owl:ObjectProperty ;
    rdfs:domain samatch:RoleAssignment ;
    rdfs:range  prov:Entity .   # Pathway | Group | Hub

samatch:roleTarget a owl:ObjectProperty ;
    rdfs:domain samatch:RoleAssignment ;
    rdfs:range  sa:Agent .

samatch:roleStatus a owl:ObjectProperty ;
    rdfs:domain samatch:RoleAssignment ;
    rdfs:range  skos:Concept .   # Active | Lapsed | Ended

# =============================================================================
# MatchInitiation  (spec 001 — direct-lane intent marketplace)
# =============================================================================
#
# IA classification: docs/information-architecture/10-intent-marketplace-classification.md § 2.1
#
# Resolutions of Ontologist open questions, codified here:
#   • O2 — ONE class with sa:visibility predicate (mirrors saint:Intent
#          tier handling); no PublicMatchInitiation / PrivateMatchInitiation
#          subclasses.
#   • O4 — basis is JSON literal (xsd:string) for v1; promote to typed
#          predicates only when SPARQL needs to filter on rank components.
#   • O6 — status values codified as skos:Concept individuals in
#          cbox/controlled-vocabularies.ttl (MatchInitiationStatus*).
#          Same pattern for initiationKind.
#   • O7 — single sa:MatchInitiationAssertion class on chain; the
#          sa:initiationKind discriminator (self|connector) is enough.
#          No separate ConnectorMatchInitiation event class.
#   • O10 — initiator owns the artifact; intent expressers receive
#          notifications, not replicas. No-duplication (P4) preserved.

sa:MatchInitiation
    a owl:Class ;
    rdfs:subClassOf prov:Entity , dul:Situation ;
    skos:relatedMatch saint:IntentMatch ;
    rdfs:label "Match Initiation" ;
    rdfs:comment "An act of putting two opposite-direction intents on the table together as a candidate pairing. Owned by the initiator (the agent that proposed the pairing); references the two source intents. The terminal artifact of spec 001's direct lane and the trigger that flips both source intents from 'expressed' to 'acknowledged'. Distinct from saint:IntentMatch, which is the durable matched pair; a MatchInitiation is the *proposal* that may become a Match." .

sa:MatchInitiationAssertion
    a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Match Initiation Assertion" ;
    rdfs:comment "On-chain anchor for a MatchInitiation. Minted ONLY when both source intents are public-tier (i.e. each already has its own on-chain assertion). Carries initiator + viewedIntent IRI + candidateIntent IRI + initiationKind + proposedAt. For coarse-tier the basis is omitted. NEVER minted when either source intent is private — a private intent's IRI must not appear in any public triple." .

# ─── Properties ─────────────────────────────────────────────────────

sa:initiator
    a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:subPropertyOf prov:wasAssociatedWith ;
    rdfs:domain sa:MatchInitiation ;
    rdfs:range sa:Agent ;
    rdfs:label "initiator" ;
    rdfs:comment "The agent who proposed the pairing. When initiationKind is 'self', this equals the expresser of one of the two intents; when 'connector', it is a third party. The initiator's MCP owns the body (per IA owner-routing)." .

sa:viewedIntent
    a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain sa:MatchInitiation ;
    rdfs:range saint:Intent ;
    rdfs:label "viewed intent" ;
    rdfs:comment "The intent the initiator was looking at when proposing the pairing. Functional — exactly one." .

sa:candidateIntent
    a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain sa:MatchInitiation ;
    rdfs:range saint:Intent ;
    rdfs:label "candidate intent" ;
    rdfs:comment "The chosen counter-intent. Direction must be opposite of viewedIntent.direction; object must match (or broaden, per FR-010). Functional — exactly one." .

sa:initiationKind
    a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain sa:MatchInitiation ;
    rdfs:range sa:MatchInitiationKind ;
    rdfs:label "initiation kind" ;
    rdfs:comment "'self' if initiator is one of the two intents' expressers; 'connector' otherwise. Discriminator for connector-mode (third-party-proposed) initiations." .

sa:proposedAt
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:subPropertyOf prov:generatedAtTime ;
    rdfs:domain sa:MatchInitiation ;
    rdfs:range xsd:dateTime ;
    rdfs:label "proposed at" ;
    rdfs:comment "ISO timestamp when the initiation was created." .

sa:basis
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain sa:MatchInitiation ;
    rdfs:range xsd:string ;
    rdfs:label "rank basis snapshot" ;
    rdfs:comment "JSON literal — opaque to SPARQL by design (O4). Snapshot of RankBasis at proposal time: { proximityHops, proximityScore, priorOutcomes, outcomeScore, composite, isColdStart }. Promote individual fields to predicates only when SPARQL needs to filter on them." .

sa:status
    a owl:ObjectProperty ;
    rdfs:domain sa:MatchInitiation ;
    rdfs:range skos:Concept ;
    rdfs:label "status" ;
    rdfs:comment "Lifecycle status. Range is shared across MatchInitiation, PoolPledge, GrantProposal — the actual concept individuals (sa:MatchInitiationStatusPending etc.) carry the artifact-specific scheme membership in C-Box." .

sa:visibility
    a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain sa:MatchInitiation ;
    rdfs:range sageo:Visibility ;
    rdfs:label "visibility tier" ;
    rdfs:comment "Reuses sageo:Visibility (Public / PublicCoarse / PrivateCommitment / PrivateZk / OffchainOnly). Cascade rule (SHACL in tbox/shacl/visibility.ttl): a MatchInitiation's tier equals the STRICTEST of its two source intents' tiers. Anchors on-chain only when Public or PublicCoarse." .

sa:onChainAssertionId
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain prov:Entity ;
    rdfs:range xsd:string ;
    rdfs:label "on-chain assertion id" ;
    rdfs:comment "IRI / id of the on-chain assertion anchoring this artifact. Null when the artifact never anchors (private tier). Shared across MatchInitiation / PoolPledge / GrantProposal / Round." .

# ─── Status / Kind classes (concept individuals in C-Box) ───────────

sa:MatchInitiationKind
    a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Match Initiation Kind" ;
    rdfs:comment "Closed enumeration: self | connector. Concept individuals in cbox/controlled-vocabularies.ttl." .

sa:MatchInitiationStatus
    a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Match Initiation Status" ;
    rdfs:comment "Closed enumeration: pending | superseded | consumed. This spec writes 'pending' only; downstream commitment / supersede paths advance status. Concept individuals in cbox/controlled-vocabularies.ttl." .

# ─── Cross-ontology alignment ───────────────────────────────────────

sa:MatchInitiation skos:relatedMatch hub:IntentMatch ;
    skos:relatedMatch samatch:NeedResourceMatch .
