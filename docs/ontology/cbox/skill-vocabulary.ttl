    a saskill:Custom ;
    skos:inScheme saskill:SkillScheme ;
    skos:prefLabel "Community organizing"@en ;
    skos:altLabel "Grassroots organizing" .

<https://smartagent.io/skill/custom/volunteer-coordination>
    a saskill:Custom ;
    skos:inScheme saskill:SkillScheme ;
    skos:prefLabel "Volunteer coordination"@en ;
    skos:broader <https://smartagent.io/skill/custom/nonprofit-development> .

<https://smartagent.io/skill/custom/case-management>
    a saskill:Custom ;
    skos:inScheme saskill:SkillScheme ;
    skos:prefLabel "Case management"@en ;
    skos:scopeNote "Coordinating services for individuals/families across providers." .

<https://smartagent.io/skill/custom/social-work>
    a saskill:Domain ;
    skos:inScheme saskill:SkillScheme ;
    skos:prefLabel "Social work"@en .

