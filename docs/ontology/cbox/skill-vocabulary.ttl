@prefix saskill: <https://smartagent.io/ontology/skill#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

# =============================================================================
# Smart Agent Skill Vocabulary  (C-Box, hand-curated for v0)
# =============================================================================
#
# Concrete skill instances grouped under saskill:SkillScheme. Mirrors
# cbox/hub-vocabulary.ttl in pattern (instances live in C-Box; T-Box
# stays for classes / properties).
#
# v0 ships a hand-curated ~30 skills relevant to the demo communities
# (Catalyst NoCo, Mission Collective, Global.Church). Full OASF import
# is deferred to v1 — the cost of adding it now is taxonomy-curation
# overhead the search-quality story doesn't yet justify.
#
# Naming: each instance IRI is .../skill/<scheme>/<conceptId>. The
# matching on-chain skillId is keccak256("skill|<scheme>|<conceptId>|").

# ─── Communication & writing ──────────────────────────────────────────

<https://smartagent.io/skill/custom/grant-writing>
    a saskill:Custom ;
    skos:inScheme saskill:SkillScheme ;
    skos:prefLabel "Grant writing"@en ;
    skos:altLabel "Grant proposal writing"@en, "Foundation grant authoring"@en ;
    skos:broader <https://smartagent.io/skill/custom/nonprofit-development> ;
    skos:definition "Authoring competitive grant proposals for foundations, government programs, and donor-advised funds." .

<https://smartagent.io/skill/custom/technical-writing>
    a saskill:Custom ;
    skos:inScheme saskill:SkillScheme ;
    skos:prefLabel "Technical writing"@en ;
    skos:altLabel "Technical documentation", "Developer documentation" .

<https://smartagent.io/skill/custom/copywriting>
    a saskill:Custom ;
    skos:inScheme saskill:SkillScheme ;
    skos:prefLabel "Copywriting"@en ;
    skos:altLabel "Marketing copy", "Brand copy" .

<https://smartagent.io/skill/custom/translation-spanish-english>
    a saskill:Custom ;
    skos:inScheme saskill:SkillScheme ;
    skos:prefLabel "Spanish ↔ English translation"@en ;
    skos:altLabel "Spanish translation", "English translation" .

