@prefix sapg: <https://smartagent.io/ontology/people-groups#> .
@prefix sageo: <https://smartagent.io/ontology/geo#> .
@prefix sa:   <https://smartagent.io/ontology/core#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# =============================================================================
# SHACL shapes for Smart Agent People-Groups ontology
# =============================================================================
#
# These shapes are validated:
#   1. At MCP write time as application-layer conditional checks (the MCP does
#      NOT run a SHACL engine in the write path).
#   2. Out-of-band against the GraphDB-mirrored T0/T1 graph post-sync. Output
#      is curator-only (ADR-PG-7) — never sponsor-readable.
#
# Per-scope-type required-predicate matrix is the central correctness rule.

# ─── Population segment ────────────────────────────────────────────────

sapg:PeopleGroupPopulationSegmentShape a sh:NodeShape ;
    sh:targetClass sapg:PeopleGroupPopulationSegment ;
    sh:property [
        sh:path sapg:ofPeopleGroup ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "PopulationSegment must reference exactly one PeopleGroup concept."@en ;
    ] ;
    sh:property [
        sh:path sapg:hasScopeType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sapg:PeopleGroupScopeType ;
        sh:message "PopulationSegment must have exactly one scope type."@en ;
    ] ;
    sh:property [
        sh:path sapg:visibility ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ("public" "sponsor-private") ;
        sh:message "Visibility must be 'public' or 'sponsor-private' (no default)."@en ;
    ] ;
    sh:property [
        sh:path sapg:sponsoringOrgPrincipal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class sa:OrganizationAgent ;
    ] .

# ─── Per-scope-type required-predicate matrix ─────────────────────────
# Each shape below targets segments carrying a specific scope type and
# enforces the predicate that scope type semantically requires.

sapg:InCityRequiresLocatedIn a sh:NodeShape ;
    sh:targetSubjectsOf sapg:hasScopeType ;
    sh:sparql [
        sh:message "Segments with hasScopeType=PeopleGroupInCity must declare locatedIn."@en ;
        sh:select """
            PREFIX sapg: <https://smartagent.io/ontology/people-groups#>
            SELECT $this WHERE {
              $this sapg:hasScopeType sapg:PeopleGroupInCity .
              FILTER NOT EXISTS { $this sapg:locatedIn ?p }
            }
        """ ;
    ] .

sapg:InCountryRequiresLocatedIn a sh:NodeShape ;
    sh:targetSubjectsOf sapg:hasScopeType ;
    sh:sparql [
        sh:message "Segments with hasScopeType=PeopleGroupInCountry must declare locatedIn."@en ;
        sh:select """
            PREFIX sapg: <https://smartagent.io/ontology/people-groups#>
            SELECT $this WHERE {
