sapg:InPolygonRequiresGeometry a sh:NodeShape ;
    sh:targetSubjectsOf sapg:hasScopeType ;
    sh:sparql [
        sh:message "Segments with hasScopeType=PeopleGroupInPolygon must declare hasGeometry."@en ;
        sh:select """
            PREFIX sapg: <https://smartagent.io/ontology/people-groups#>
            SELECT $this WHERE {
              $this sapg:hasScopeType sapg:PeopleGroupInPolygon .
              FILTER NOT EXISTS { $this sapg:hasGeometry ?g }
            }
        """ ;
    ] .

sapg:InDiasporaRequiresHomelandAndHost a sh:NodeShape ;
    sh:targetSubjectsOf sapg:hasScopeType ;
    sh:sparql [
        sh:message "Segments with hasScopeType=PeopleGroupInDiaspora must set isDiasporaPopulation=true and declare homelandPlace + hostPlace."@en ;
        sh:select """
            PREFIX sapg: <https://smartagent.io/ontology/people-groups#>
            SELECT $this WHERE {
              $this sapg:hasScopeType sapg:PeopleGroupInDiaspora .
              FILTER NOT EXISTS {
                $this sapg:isDiasporaPopulation true ;
                      sapg:homelandPlace ?h ;
                      sapg:hostPlace ?p .
              }
            }
        """ ;
    ] .

