# ─── PROV-O integrity for assessment data ──────────────────────────────

sapg:AssessmentDatumProvenanceShape a sh:NodeShape ;
    sh:targetClass sapg:AssessmentDatum ;
    sh:property [
        sh:path prov:wasDerivedFrom ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Every AssessmentDatum (estimate / assessment / classification) must declare at least one prov:wasDerivedFrom source."@en ;
    ] ;
    sh:property [
        sh:path prov:wasGeneratedBy ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path sapg:confidenceScore ;
        sh:datatype xsd:decimal ;
        sh:minInclusive "0.0"^^xsd:decimal ;
        sh:maxInclusive "1.0"^^xsd:decimal ;
        sh:message "confidenceScore must be in [0.0, 1.0]."@en ;
    ] .

sapg:PopulationEstimateShape a sh:NodeShape ;
    sh:targetClass sapg:PeopleGroupPopulationEstimate ;
    sh:property [
        sh:path sapg:estimateForPopulationSegment ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sapg:PeopleGroupPopulationSegment ;
    ] ;
    sh:property [
        sh:path sapg:populationCount ;
        sh:datatype xsd:nonNegativeInteger ;
    ] ;
    sh:property [
        sh:path sapg:percentChristian ;
        sh:datatype xsd:decimal ;
        sh:minInclusive "0.0"^^xsd:decimal ;
        sh:maxInclusive "1.0"^^xsd:decimal ;
    ] ;
    sh:property [
        sh:path sapg:percentEvangelical ;
        sh:datatype xsd:decimal ;
        sh:minInclusive "0.0"^^xsd:decimal ;
        sh:maxInclusive "1.0"^^xsd:decimal ;
    ] .

sapg:ReachednessAssessmentShape a sh:NodeShape ;
    sh:targetClass sapg:ReachednessAssessment ;
    sh:property [
        sh:path sapg:assessmentOfPopulationSegment ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sapg:PeopleGroupPopulationSegment ;
    ] ;
    sh:property [
        sh:path sapg:reachednessStatus ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
        sh:message "reachednessStatus must reference the sapg:ReachednessStatusScheme C-Box."@en ;
    ] ;
    sh:property [
        sh:path sapg:engagementStatus ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] .

# ─── Community ↔ segment compatibility ─────────────────────────────────

sapg:CommunitySegmentConceptCompatibility a sh:NodeShape ;
    sh:targetClass sapg:PeopleGroupCommunity ;
    sh:sparql [
        sh:message "All segments referenced by a community via communityWithinPopulationSegment must share the same ofPeopleGroup concept (single-concept community)."@en ;
        sh:select """
            PREFIX sapg: <https://smartagent.io/ontology/people-groups#>
            SELECT $this WHERE {
              $this sapg:communityWithinPopulationSegment ?s1 ;
                    sapg:communityWithinPopulationSegment ?s2 .
              ?s1 sapg:ofPeopleGroup ?c1 .
              ?s2 sapg:ofPeopleGroup ?c2 .
              FILTER (?c1 != ?c2)
            }
        """ ;
    ] .

# ─── Diaspora boolean conditional ──────────────────────────────────────

sapg:DiasporaBooleanRequirements a sh:NodeShape ;
    sh:targetClass sapg:PeopleGroupPopulationSegment ;
    sh:sparql [
        sh:message "When isDiasporaPopulation=true, both homelandPlace and hostPlace must be declared."@en ;
        sh:select """
            PREFIX sapg: <https://smartagent.io/ontology/people-groups#>
            SELECT $this WHERE {
              $this sapg:isDiasporaPopulation true .
              FILTER NOT EXISTS { $this sapg:homelandPlace ?h }
              FILTER NOT EXISTS { $this sapg:hostPlace ?p }
            }
        """ ;
    ] .

# ─── Reachedness as assessment, never as subclass ──────────────────────
# Documented constraint, not enforced via SHACL: there must NOT be a class
# named sapg:UnreachedPeopleGroup or sapg:FrontierPeopleGroup. Reachedness
# lives on sapg:ReachednessAssessment as an assessment of a segment.
