@prefix sa:    <https://smartagent.io/ontology/core#> .
@prefix sai:   <https://smartagent.io/ontology/identity#> .
@prefix sar:   <https://smartagent.io/ontology/relationships#> .
@prefix sad:   <https://smartagent.io/ontology/delegation#> .
@prefix sag:   <https://smartagent.io/ontology/governance#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# =============================================================================
# Controlled Vocabularies  (C-Box)
# =============================================================================
#
# Enumeration members and SKOS concept individuals that define what values
# are VALID for each classification in the T-Box. These constrain what
# instances in the A-Box can reference.
#
# T-Box defines the class (e.g., sa:AIAgentClass).
# C-Box defines the allowed members (e.g., sa:ExecutorClass).
# A-Box assigns them to instances (e.g., agent X sai:aiAgentClass sa:ExecutorClass).
#
# Version: 0.2.0
# =============================================================================


# =============================================================================
# AI Agent Class Vocabulary
# =============================================================================
# Class sa:AIAgentClass defined in tbox/core.ttl

sa:AIAgentClassScheme  a skos:ConceptScheme ; rdfs:label "AI Agent Class Scheme" .

sa:DiscoveryClass   a sa:AIAgentClass, skos:Concept ; skos:inScheme sa:AIAgentClassScheme ; rdfs:label "Discovery"  ; rdfs:comment "Search, indexing, and knowledge discovery."                     ; sa:onChainClassHash "CLASS_DISCOVERY" .
sa:ValidatorClass   a sa:AIAgentClass, skos:Concept ; skos:inScheme sa:AIAgentClassScheme ; rdfs:label "Validator"   ; rdfs:comment "Verification, validation, and assurance."                       ; sa:onChainClassHash "CLASS_VALIDATOR" .
sa:ExecutorClass    a sa:AIAgentClass, skos:Concept ; skos:inScheme sa:AIAgentClassScheme ; rdfs:label "Executor"    ; rdfs:comment "Transaction execution within delegated bounds."                 ; sa:onChainClassHash "CLASS_EXECUTOR" .
sa:AssistantClass   a sa:AIAgentClass, skos:Concept ; skos:inScheme sa:AIAgentClassScheme ; rdfs:label "Assistant"   ; rdfs:comment "Advisory, planning, or conversational assistance."              ; sa:onChainClassHash "CLASS_ASSISTANT" .
sa:OracleClass      a sa:AIAgentClass, skos:Concept ; skos:inScheme sa:AIAgentClassScheme ; rdfs:label "Oracle"      ; rdfs:comment "External data feeds, price oracles, or off-chain attestations." ; sa:onChainClassHash "CLASS_ORACLE" .
sa:CustomClass      a sa:AIAgentClass, skos:Concept ; skos:inScheme sa:AIAgentClassScheme ; rdfs:label "Custom"      ; rdfs:comment "Application-specific classification."                           ; sa:onChainClassHash "CLASS_CUSTOM" .


# =============================================================================
# Edge Status Vocabulary
# =============================================================================
# Class sar:EdgeStatus defined in tbox/relationships.ttl

sar:EdgeStatusScheme  a skos:ConceptScheme ; rdfs:label "Edge Status Scheme" .

sar:StatusNone       a sar:EdgeStatus, skos:Concept ; skos:inScheme sar:EdgeStatusScheme ; rdfs:label "None"      ; skos:notation "0" .
sar:StatusProposed   a sar:EdgeStatus, skos:Concept ; skos:inScheme sar:EdgeStatusScheme ; rdfs:label "Proposed"   ; skos:notation "1" .
sar:StatusConfirmed  a sar:EdgeStatus, skos:Concept ; skos:inScheme sar:EdgeStatusScheme ; rdfs:label "Confirmed"  ; skos:notation "2" .
sar:StatusActive     a sar:EdgeStatus, skos:Concept ; skos:inScheme sar:EdgeStatusScheme ; rdfs:label "Active"     ; skos:notation "3" .
sar:StatusSuspended  a sar:EdgeStatus, skos:Concept ; skos:inScheme sar:EdgeStatusScheme ; rdfs:label "Suspended"  ; skos:notation "4" .
sar:StatusRevoked    a sar:EdgeStatus, skos:Concept ; skos:inScheme sar:EdgeStatusScheme ; rdfs:label "Revoked"    ; skos:notation "5" .
sar:StatusRejected   a sar:EdgeStatus, skos:Concept ; skos:inScheme sar:EdgeStatusScheme ; rdfs:label "Rejected"   ; skos:notation "6" .


# =============================================================================
# Assertion Type Vocabulary
# =============================================================================
# Class sar:AssertionType defined in tbox/relationships.ttl

sar:AssertionTypeScheme  a skos:ConceptScheme ; rdfs:label "Assertion Type Scheme" .

sar:SelfAsserted       a sar:AssertionType, skos:Concept ; skos:inScheme sar:AssertionTypeScheme ; rdfs:label "Self-Asserted"        ; skos:notation "1" .
sar:ObjectAsserted     a sar:AssertionType, skos:Concept ; skos:inScheme sar:AssertionTypeScheme ; rdfs:label "Object-Asserted"      ; skos:notation "2" .
sar:MutualConfirmation a sar:AssertionType, skos:Concept ; skos:inScheme sar:AssertionTypeScheme ; rdfs:label "Mutual Confirmation"  ; skos:notation "3" .
sar:ValidatorAsserted  a sar:AssertionType, skos:Concept ; skos:inScheme sar:AssertionTypeScheme ; rdfs:label "Validator-Asserted"   ; skos:notation "4" .
sar:OrgAsserted        a sar:AssertionType, skos:Concept ; skos:inScheme sar:AssertionTypeScheme ; rdfs:label "Org-Asserted"         ; skos:notation "5" .
sar:AppAsserted        a sar:AssertionType, skos:Concept ; skos:inScheme sar:AssertionTypeScheme ; rdfs:label "App-Asserted"         ; skos:notation "6" .


# =============================================================================
# Relationship Type Vocabulary
# =============================================================================
# Abstract classes (InstitutionalRelationship, etc.) stay in T-Box.
# Concrete type individuals moved here as controlled vocabulary.

sar:RelationshipTypeScheme  a skos:ConceptScheme ; rdfs:label "Relationship Type Scheme" .

sar:OrganizationGovernance  a sar:InstitutionalRelationship, skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Governance"            ; skos:notation "organization-governance"  ; sa:onChainTermHash "keccak256('atl:OrganizationGovernanceRelationship')" .
sar:OrganizationMembership  a sar:InstitutionalRelationship, skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Membership"            ; skos:notation "organization-membership"  ; sa:onChainTermHash "keccak256('atl:OrganizationMembershipRelationship')" .
sar:Alliance                a sar:NetworkRelationship,       skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Alliance"              ; skos:notation "alliance"                 ; sa:onChainTermHash "keccak256('atl:AllianceRelationship')" .
sar:ValidationTrust         a sar:AssuranceRelationship,     skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Validation"            ; skos:notation "validation-trust"         ; sa:onChainTermHash "keccak256('atl:ValidationTrustRelationship')" .
sar:InsuranceCoverage       a sar:AssuranceRelationship,     skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Insurance"             ; skos:notation "insurance-coverage"       ; sa:onChainTermHash "keccak256('atl:InsuranceCoverageRelationship')" .
sar:Compliance              a sar:AssuranceRelationship,     skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Compliance"            ; skos:notation "compliance"               ; sa:onChainTermHash "keccak256('atl:ComplianceRelationship')" .
sar:EconomicSecurity        a sar:CapitalRelationship,       skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Economic Security"     ; skos:notation "economic-security"        ; sa:onChainTermHash "keccak256('atl:EconomicSecurityRelationship')" .
sar:ServiceAgreement        a sar:ExecutionRelationship,     skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Service"               ; skos:notation "service-agreement"        ; sa:onChainTermHash "keccak256('atl:ServiceAgreementRelationship')" .
sar:DelegationAuthority     a sar:ExecutionRelationship,     skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Delegation"            ; skos:notation "delegation-authority"     ; sa:onChainTermHash "keccak256('atl:DelegationAuthorityRelationship')" .
sar:RuntimeAttestation      a sar:InfrastructureRelationship, skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Runtime/TEE"          ; skos:notation "runtime-attestation"     ; sa:onChainTermHash "keccak256('atl:RuntimeAttestationRelationship')" .
sar:BuildProvenance         a sar:InfrastructureRelationship, skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Build Provenance"     ; skos:notation "build-provenance"        ; sa:onChainTermHash "keccak256('atl:BuildProvenanceRelationship')" .
sar:OrganizationalControl   a sar:ExecutionRelationship,     skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Org Control"           ; skos:notation "organizational-control"  ; sa:onChainTermHash "keccak256('atl:OrganizationalControlRelationship')" .
sar:ActivityValidation      a sar:AssuranceRelationship,     skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Activity Validation"   ; skos:notation "activity-validation"     ; sa:onChainTermHash "keccak256('atl:ActivityValidationRelationship')" .
sar:Review                  a sar:AssuranceRelationship,     skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Review"                ; skos:notation "review"                  ; sa:onChainTermHash "keccak256('atl:ReviewRelationship')" .
sar:HasMember               a sar:NetworkRelationship,       skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Hub Membership"        ; skos:notation "has-member"              ; sa:onChainTermHash "keccak256('atl:HasMemberRelationship')" .
sar:GenerationalLineage     a sar:NetworkRelationship,       skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Generational Lineage"  ; skos:notation "generational-lineage"    ; sa:onChainTermHash "keccak256('atl:GenerationalLineageRelationship')" .
sar:CoachingMentorship      a sar:AssuranceRelationship,     skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Coaching"              ; skos:notation "coaching-mentorship"     ; sa:onChainTermHash "keccak256('atl:CoachingMentorshipRelationship')" .
sar:PersonalInfluence       a sar:NetworkRelationship,       skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Personal Influence"    ; skos:notation "personal-influence"      ; sa:onChainTermHash "keccak256('atl:PersonalInfluenceRelationship')" .
sar:DataAccessDelegation    a sar:NetworkRelationship,       skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Data Access Delegation" ; skos:notation "data-access-delegation" ; sa:onChainTermHash "keccak256('atl:DataAccessDelegationRelationship')" .
sar:NamespaceContains       a sar:NetworkRelationship,       skos:Concept ; skos:inScheme sar:RelationshipTypeScheme ; rdfs:label "Namespace Contains"    ; skos:notation "namespace-contains"      ; sa:onChainTermHash "keccak256('atl:NamespaceContainsRelationship')" .


# =============================================================================
# Role Vocabulary
# =============================================================================
# Role category classes (GovernanceRole, etc.) stay in T-Box.
# Concrete role individuals moved here as controlled vocabulary.

sar:RoleScheme  a skos:ConceptScheme ; rdfs:label "Role Scheme" .

# ─── Governance ──────────────────────────────────────────────────────
sar:Owner             a sar:GovernanceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "owner"            ; skos:notation "owner"            ; sa:onChainTermHash "keccak256('atl:OwnerRole')"           ; sar:applicableToRelationshipType sar:OrganizationGovernance .
sar:BoardMember       a sar:GovernanceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "board-member"     ; skos:notation "board-member"     ; sa:onChainTermHash "keccak256('atl:BoardMemberRole')"     ; sar:applicableToRelationshipType sar:OrganizationGovernance .
sar:ChiefExecutive    a sar:GovernanceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "ceo"              ; skos:notation "ceo"              ; sa:onChainTermHash "keccak256('atl:ChiefExecutiveRole')"  ; sar:applicableToRelationshipType sar:OrganizationGovernance .
sar:Executive         a sar:GovernanceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "executive"        ; skos:notation "executive"        ; sa:onChainTermHash "keccak256('atl:ExecutiveRole')"       ; sar:applicableToRelationshipType sar:OrganizationGovernance .
sar:Treasurer         a sar:GovernanceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "treasurer"        ; skos:notation "treasurer"        ; sa:onChainTermHash "keccak256('atl:TreasurerRole')"       ; sar:applicableToRelationshipType sar:OrganizationGovernance , sar:OrganizationMembership .
sar:AuthorizedSigner  a sar:GovernanceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "authorized-signer" ; skos:notation "authorized-signer" ; sa:onChainTermHash "keccak256('atl:AuthorizedSignerRole')" ; sar:applicableToRelationshipType sar:OrganizationGovernance , sar:OrganizationMembership , sar:DelegationAuthority .
sar:Officer           a sar:GovernanceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "officer"          ; skos:notation "officer"          ; sa:onChainTermHash "keccak256('atl:OfficerRole')"         ; sar:applicableToRelationshipType sar:OrganizationGovernance .
sar:Chair             a sar:GovernanceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "chair"            ; skos:notation "chair"            ; sa:onChainTermHash "keccak256('atl:ChairRole')"           ; sar:applicableToRelationshipType sar:OrganizationGovernance .

# ─── Advisory ────────────────────────────────────────────────────────
sar:Advisor    a sar:AdvisoryRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "advisor"  ; skos:notation "advisor" ; sa:onChainTermHash "keccak256('atl:AdvisorRole')" ; sar:applicableToRelationshipType sar:OrganizationGovernance , sar:OrganizationMembership .

# ─── Membership ──────────────────────────────────────────────────────
sar:Administrator a sar:MembershipRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "admin"    ; skos:notation "admin"    ; sa:onChainTermHash "keccak256('atl:AdministratorRole')" ; sar:applicableToRelationshipType sar:OrganizationMembership .
sar:Member        a sar:MembershipRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "member"   ; skos:notation "member"   ; sa:onChainTermHash "keccak256('atl:MemberRole')"        ; sar:applicableToRelationshipType sar:OrganizationMembership , sar:HasMember .
sar:Operator      a sar:MembershipRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "operator" ; skos:notation "operator" ; sa:onChainTermHash "keccak256('atl:OperatorRole')"      ; sar:applicableToRelationshipType sar:OrganizationMembership .
sar:Employee      a sar:MembershipRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "employee" ; skos:notation "employee" ; sa:onChainTermHash "keccak256('atl:EmployeeRole')"      ; sar:applicableToRelationshipType sar:OrganizationMembership .

# ─── Service ─────────────────────────────────────────────────────────
sar:Contractor      a sar:ServiceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "contractor"       ; skos:notation "contractor"       ; sa:onChainTermHash "keccak256('atl:ContractorRole')"      ; sar:applicableToRelationshipType sar:ServiceAgreement .
sar:Vendor          a sar:ServiceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "vendor"           ; skos:notation "vendor"           ; sa:onChainTermHash "keccak256('atl:VendorRole')"          ; sar:applicableToRelationshipType sar:ServiceAgreement .
sar:ServiceProvider a sar:ServiceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "service-provider" ; skos:notation "service-provider" ; sa:onChainTermHash "keccak256('atl:ServiceProviderRole')" ; sar:applicableToRelationshipType sar:ServiceAgreement .

