sar:Auditor            a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "auditor"             ; skos:notation "auditor"             ; sa:onChainTermHash "keccak256('atl:AuditorRole')"            ; sar:applicableToRelationshipType sar:OrganizationMembership , sar:Review , sar:Compliance .
sar:Validator          a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "validator"           ; skos:notation "validator"           ; sa:onChainTermHash "keccak256('atl:ValidatorRole')"          ; sar:applicableToRelationshipType sar:OrganizationMembership , sar:ValidationTrust , sar:ActivityValidation .
sar:Insurer            a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "insurer"             ; skos:notation "insurer"             ; sa:onChainTermHash "keccak256('atl:InsurerRole')"            ; sar:applicableToRelationshipType sar:InsuranceCoverage .
sar:InsuredParty       a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "insured-party"       ; skos:notation "insured-party"       ; sa:onChainTermHash "keccak256('atl:InsuredPartyRole')"       ; sar:applicableToRelationshipType sar:InsuranceCoverage .
sar:Underwriter        a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "underwriter"         ; skos:notation "underwriter"         ; sa:onChainTermHash "keccak256('atl:UnderwriterRole')"        ; sar:applicableToRelationshipType sar:InsuranceCoverage .
sar:CertifiedBy        a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "certified-by"        ; skos:notation "certified-by"        ; sa:onChainTermHash "keccak256('atl:CertifiedByRole')"        ; sar:applicableToRelationshipType sar:ValidationTrust , sar:Compliance .
sar:LicensedBy         a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "licensed-by"         ; skos:notation "licensed-by"         ; sa:onChainTermHash "keccak256('atl:LicensedByRole')"         ; sar:applicableToRelationshipType sar:Compliance .
sar:ActivityValidator  a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "activity-validator"  ; skos:notation "activity-validator"  ; sa:onChainTermHash "keccak256('atl:ActivityValidatorRole')"  ; sar:applicableToRelationshipType sar:ActivityValidation .
sar:ValidatedPerformer a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "validated-performer" ; skos:notation "validated-performer" ; sa:onChainTermHash "keccak256('atl:ValidatedPerformerRole')" ; sar:applicableToRelationshipType sar:ActivityValidation .
sar:Reviewer           a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "reviewer"            ; skos:notation "reviewer"            ; sa:onChainTermHash "keccak256('atl:ReviewerRole')"           ; sar:applicableToRelationshipType sar:Review .
sar:ReviewedAgent      a sar:AssuranceRole, skos:Concept ; skos:inScheme sar:RoleScheme ; rdfs:label "reviewed-agent"      ; skos:notation "reviewed-agent"      ; sa:onChainTermHash "keccak256('atl:ReviewedAgentRole')"      ; sar:applicableToRelationshipType sar:Review .

