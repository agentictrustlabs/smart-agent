    sah:domainLabel "Generational Lineage" .

_:cat-strategic-partner-label a sah:HubVocabularyMapping ;
    sah:forHub sah:CatalystHub ;
    sah:mapsTerm sar:StrategicPartner ;
    sah:domainLabel "parent-church" .

_:cat-subsidiary-label a sah:HubVocabularyMapping ;
    sah:forHub sah:CatalystHub ;
    sah:mapsTerm sar:Subsidiary ;
    sah:domainLabel "daughter-church" .

_:cat-parent-org-label a sah:HubVocabularyMapping ;
    sah:forHub sah:CatalystHub ;
    sah:mapsTerm sar:ParentOrg ;
    sah:domainLabel "parent-church" .

_:cat-upstream-label a sah:HubVocabularyMapping ;
    sah:forHub sah:CatalystHub ;
    sah:mapsTerm sar:Upstream ;
    sah:domainLabel "parent-group" .

_:cat-downstream-label a sah:HubVocabularyMapping ;
