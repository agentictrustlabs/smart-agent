# ─── CIL Hub ────────────────────────────────────────────────────────

_:cil-alliance-label a sah:HubVocabularyMapping ;
    sah:forHub sah:CILHub ;
    sah:mapsTerm sar:Alliance ;
    sah:domainLabel "Trust Link" .

_:cil-review-label a sah:HubVocabularyMapping ;
    sah:forHub sah:CILHub ;
    sah:mapsTerm sar:Review ;
    sah:domainLabel "Assertion" .


# ─── Generic Hub — uses T-Box labels as-is, no overrides needed ──────
