{
  "@context": {
    "sa": "https://smartagent.io/ontology/core#",
    "sai": "https://smartagent.io/ontology/identity#",
    "sar": "https://smartagent.io/ontology/relationships#",
    "san": "https://smartagent.io/ontology/namespace#",
    "sageo": "https://smartagent.io/ontology/geo#",
    "sapg": "https://smartagent.io/ontology/pg#",
    "eth": "https://smartagent.io/ontology/eth#",
    "sad": "https://smartagent.io/ontology/delegation#",
    "sah": "https://smartagent.io/ontology/hub#",
    "geo": "http://www.opengis.net/ont/geosparql#",
    "geof": "http://www.opengis.net/def/function/geosparql/",
    "sf": "http://www.opengis.net/ont/sf#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "prov": "http://www.w3.org/ns/prov#",
    "skos": "http://www.w3.org/2004/02/skos/core#",

    "Agent": "sa:Agent",
    "PersonAgent": "sa:PersonAgent",
    "OrganizationAgent": "sa:OrganizationAgent",
    "AIAgentAccount": "sa:AIAgentAccount",
    "HubAgent": "sa:HubAgent",

    "DiscoveryAgent": "sa:DiscoveryClass",
    "ValidatorAgent": "sa:ValidatorClass",
    "ExecutorAgent": "sa:ExecutorClass",
    "AssistantAgent": "sa:AssistantClass",
    "OracleAgent": "sa:OracleClass",

    "accountAddress": "sa:onChainAddress",
    "displayName": "sa:displayName",
    "description": "sa:description",
    "isActive": { "@id": "sa:isActive", "@type": "xsd:boolean" },
    "uaid": "sa:uaid",

    "agentType": "sa:agentType",
    "aiAgentClass": { "@id": "sai:aiAgentClass", "@type": "@id" },

    "primaryName": "sa:primaryName",
    "nameLabel": "sa:nameLabel",

    "hasA2AEndpoint": "sai:a2aEndpoint",
    "hasMCPServer": "sai:mcpServer",
    "hasServiceEndpoint": "sai:serviceEndpoint",

    "supportedTrustModel": "sai:supportedTrustModel",
    "hasCapability": "sai:capability",

    "hasController": "sai:hasOwnerAccount",
    "operatedBy": { "@id": "sa:operatedBy", "@type": "@id" },

    "metadataURI": "sai:metadataURI",
    "schemaURI": "sai:schemaURI",

    "entryPoint": "sai:entryPoint",
    "delegationManager": "sai:delegationManager",

    "latitude": "sa:latitude",
    "longitude": "sa:longitude",
    "spatialCRS": "sa:spatialCRS",
    "spatialType": "sa:spatialType",

    "RelationshipEdge": "sar:RelationshipEdge",
    "subject": { "@id": "sar:subject", "@type": "@id" },
    "object": { "@id": "sar:object", "@type": "@id" },
    "relationshipType": { "@id": "sar:relationshipType", "@type": "@id" },
    "hasRole": { "@id": "sar:hasRole", "@type": "@id" },
    "edgeStatus": { "@id": "sar:edgeStatus", "@type": "@id" },
    "edgeId": "sar:edgeId",

    "city":    "sa:city",
    "region":  "sa:region",
    "country": "sa:country",

    "GeoFeature":    "sageo:GeoFeature",
    "GeoClaim":      "sageo:GeoClaim",
    "Municipality":  "sageo:Municipality",
    "County":        "sageo:County",
    "State":         "sageo:State",
    "Country":       "sageo:Country",
    "Neighborhood":  "sageo:Neighborhood",
    "ZipCode":       "sageo:ZipCode",
    "featureId":         { "@id": "sageo:featureId", "@type": "xsd:hexBinary" },
    "featureVersion":    { "@id": "sageo:featureVersion", "@type": "xsd:positiveInteger" },
    "geometryHash":      { "@id": "sageo:geometryHash", "@type": "xsd:hexBinary" },
    "h3CoverageRoot":    { "@id": "sageo:h3CoverageRoot", "@type": "xsd:hexBinary" },
    "sourceSetRoot":     { "@id": "sageo:sourceSetRoot", "@type": "xsd:hexBinary" },
    "stewardAccount":    { "@id": "sageo:stewardAccount", "@type": "@id" },
    "targetFeature":     { "@id": "sageo:targetFeature", "@type": "@id" },
    "relation":          { "@id": "sageo:relation", "@type": "@id" },
    "visibility":        "sageo:visibility",
    "evidenceCommit":    { "@id": "sageo:evidenceCommit", "@type": "xsd:hexBinary" },
    "policyId":          "sageo:policyId",
    "hasGeometry":       { "@id": "geo:hasGeometry", "@type": "@id" },
    "asWKT":             "geo:asWKT",

    "PeopleGroup":           "sapg:PeopleGroup",
    "PeopleGroupResource":   "sapg:PeopleGroupResource",
    "peopleId3":             "sapg:peopleId3",
    "rol3":                  "sapg:rol3",
    "countryCode":           "sapg:countryCode",
    "joshuaProjectURI":      { "@id": "sapg:joshuaProjectURI", "@type": "@id" },
    "ethnologueURI":         { "@id": "sapg:ethnologueURI", "@type": "@id" },
    "memberOf":              { "@id": "sapg:memberOf", "@type": "@id" },
    "servesAmong":           { "@id": "sapg:servesAmong", "@type": "@id" },

    "NamespaceRoot":   "san:NamespaceRoot",
    "NameRecord":      "san:NameRecord",
    "rootLabel":       "san:rootLabel",
    "hasKind":         { "@id": "san:hasKind", "@type": "@id" },
    "resourceRef":     { "@id": "san:resourceRef", "@type": "@id" }
  }
}
