# ─── Native Auth ─────────────────────────────────────────────────────
# Sprint 2 S2.4 — multi-key signing + verification for the session JWT.
#
# SESSION_JWT_SECRETS is a comma-separated list of `kid:secret_hex` pairs.
# The FIRST entry is the ACTIVE signing key; ALL entries remain valid
# for verification. During rotation, prepend a new kid:secret and keep
# the old kid in the list for at least the cookie TTL (24h, see
# SESSION_TTL_SECONDS in apps/web/src/lib/auth/native-session.ts), then
# drop it. Generate keys with `openssl rand -hex 32`.
#
# Example (active = 2026-05-v2, legacy = 2026-05-v1):
#   SESSION_JWT_SECRETS=2026-05-v2:5e4f...32bytes,2026-05-v1:abc1...32bytes
#
# Runbook: docs/operations/kms-signer-setup.md
#   § "Session JWT signing key (Sprint 2 S2.4)"
#
# Production guards (apps/web/src/lib/auth/jwt.ts → loadJwtKeys):
#   - NODE_ENV=production AND no SESSION_JWT_SECRETS → throw at first use.
#   - NODE_ENV=production AND active kid == "dev-fallback" → throw.
SESSION_JWT_SECRETS=

# LEGACY (verify-only, deprecated). If SESSION_JWT_SECRETS is unset and
# this is set, tokens signed under the pre-S2.4 single-secret scheme
# (no `kid` header) still verify — but minting NEW tokens is refused
# (operators must opt into rotation by switching to the plural form).
# Leave EMPTY on greenfield deployments.
SESSION_JWT_SECRET=

# ─── CSRF origin allowlist (S2.2) ────────────────────────────────────
# Comma-separated list of fully-qualified origins permitted to make
# state-changing requests to /api/* routes. Checked via parsed-URL
# protocol + host equality (NOT substring) — the old substring check
# admitted `Origin: https://evil-foo.com` against `Host: foo.com`.
#
# Each entry MUST include scheme. `URL.host` covers hostname + port,
# so explicit ports are required when non-default. Examples:
#   ALLOWED_ORIGINS=http://localhost:3000
#   ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
#
# Unset → defaults to http://localhost:3000 (local dev only).
# Production deployments MUST set this to their public app origin(s).
ALLOWED_ORIGINS=http://localhost:3000

# ─── Google OAuth (social login) ─────────────────────────────────────
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google-callback
# Sprint S2.6 — `oauth-salt` MAC key. The deterministic salt that pins a
# google identity to its smart-account address is now a KMS-HMAC over a
# canonical message (replaces the legacy SERVER_PEPPER symmetric secret).
#
#   Local dev: hex-encoded 32-byte HMAC key. The `local-hmac` provider
#              reads this and signs in-process. Refuses NODE_ENV=production.
OAUTH_SALT_HMAC_KEY=
#
#   Production (Vercel): set instead
#     A2A_KMS_BACKEND=aws-kms
#     AWS_REGION / AWS_ROLE_ARN (shared with the K3-ext family)
#     AWS_KMS_MAC_KEY_ID_OAUTH_SALT=arn:aws:kms:...:key/<UUID>
#   Provisioning runbook: docs/operations/kms-signer-setup.md
#   § "OAuth salt MAC key (S2.6)".
#
# Treat like a key — rotating it changes every Google user's account
# address (no migration path). Same posture as the legacy SERVER_PEPPER.
#
# Legacy SERVER_PEPPER is REMOVED from the google-oauth path. The variable
# is still consumed by the dev-only `dev-pepper` session-signer custody
# backend below (unrelated to OAuth); production never sets it.
SERVER_PEPPER=

# ─── Session-signer custody backend (Sprint S1.1) ───────────────────
# Selects which key-custody backend mints session-EOA signers for the
# unified passkey + grant ceremony (/api/auth/session-grant/*).
#
#   dev-pepper  — HKDF over SERVER_PEPPER, signs in process (DEV ONLY).
#   aws-kms     — AWS KMS asymmetric ECC_SECG_P256K1 key; kms:Sign per
#                 request. Required in production; the factory rejects
#                 `dev-pepper` when NODE_ENV=production (S1.4 guard).
SESSION_SIGNER_BACKEND=dev-pepper
# AWS KMS env (only needed when SESSION_SIGNER_BACKEND=aws-kms). The
# signer CMK is a SEPARATE key from AWS_KMS_SIGNER_KEY_ID (the a2a-agent's
# master EOA signer) so the two runtimes have distinct IAM scopes and
# independent rotation cadences. See
# docs/operations/kms-signer-setup.md § "Web session-grant signer key (S1.1)".
AWS_REGION=
AWS_ROLE_ARN=
AWS_WEB_SESSION_SIGNER_KEY_ID=

# ─── Privy Auth (LEGACY — kept for older demo cookie fallback) ──────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── Chain Config ────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=31337

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=local.db

# ─── RPC & Deployer (set by scripts/deploy-local.sh) ────────────────
RPC_URL=http://127.0.0.1:8545
# DEPLOYER_PRIVATE_KEY (K6): present in LOCAL DEV ONLY for the legacy
# `getWalletClient()` relayer used by demo-seed + a small number of
# transitive action-layer callers (tracked as Phase 2 consolidation
# debt in scripts/check-no-bypass.sh). Post-K6 S1.5 the three
# bootstrap-auth handlers (`siwe-verify`, `passkey-signup`,
# `google-callback`) sign via the `auth-bootstrap` tool-executor key
# below — NOT this deployer key. In production this key MUST NOT be in
# runtime env — it's a CI/CD-only secret used by
# `forge script Deploy.s.sol`. See
# docs/operations/kms-signer-setup.md § "Deployer key (K6 — CI/CD only)".
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# DEPLOYER_ADDRESS (K6): the production-correct way to surface the
# deployer identity at runtime — address only, no key. Routes that
# only need the address (e.g. counterfactual smart-account preview)
# read this instead of deriving from the private key.
DEPLOYER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# ─── auth-bootstrap tool-executor (K6 S1.5) ─────────────────────────
# Signs system operations the user can't perform themselves at first
# sign-in (smart-account deploy, .agent name register, resolver
# bootstrap, deterministic account derivation) for the three web
# bootstrap-auth handlers:
#   /api/auth/siwe-verify   /api/auth/passkey-signup   /api/auth/google-callback
#
# Separate identity from the deployer — its private material lives in
# a per-tool KMS slot in production (Category D). In local dev,
# scripts/deploy-local.sh seeds this with anvil account #9
# (deterministic). Web reads it via
# `apps/web/src/lib/key-custody/tool-executor.ts` → getAuthBootstrapSigner().
# Selected by the same `A2A_KMS_BACKEND` env as the K4/K5 signers.
#
# Dev (local-aes) form — populated by scripts/deploy-local.sh:
TOOL_EXECUTOR_AUTH_BOOTSTRAP_PRIVATE_KEY=0x2a871d0798f97d79848a013d4936a73bf4cc922c825d33c1cf7073dff6d409c6
# Prod (aws-kms) form — per
# docs/operations/kms-signer-setup.md § "Tool-executor signer keys (K5)":
# AWS_KMS_TOOL_EXECUTOR_AUTH_BOOTSTRAP_KEY_ID=arn:aws:kms:us-east-1:111122223333:key/eeee5555-...

# ─── Deployed Contract Addresses (set by scripts/deploy-local.sh) ───
ENTRYPOINT_ADDRESS=
AGENT_FACTORY_ADDRESS=
DELEGATION_MANAGER_ADDRESS=
TIMESTAMP_ENFORCER_ADDRESS=
VALUE_ENFORCER_ADDRESS=
ALLOWED_TARGETS_ENFORCER_ADDRESS=
ALLOWED_METHODS_ENFORCER_ADDRESS=
RECOVERY_ENFORCER_ADDRESS=

# ─── Recovery flow (Phase 3) ─────────────────────────────────────────
# Timelock between RecoveryEnforcer.propose() and successful redemption.
# Production: 86400 (24h). Demo/dev: 60 keeps the flow testable.
RECOVERY_DELAY_SECONDS=60

# ─── A2A host routing (Phase 2 of A2A-first routing) ────────────────
# DEPRECATED: A2A_AGENT_URL — host-aware routing supersedes the single
# A2A endpoint. The web tier now resolves a per-agent subdomain like
# `<slug>.agent.localhost:3100`, where the slug is the leftmost label of
# the agent's ATL_PRIMARY_NAME. Override only for non-local deployments.
NEXT_PUBLIC_A2A_HOST_BASE=agent.localhost:3100
# Optional — override the URL scheme used when the web tier talks to the
# A2A agent (defaults to http). Useful when terminating TLS in front of
# the A2A process in production.
NEXT_PUBLIC_A2A_SCHEME=http
