# org-mcp environment template.
#
# Local dev: copy to `.env` and let `scripts/deploy-local.sh` fill in
# contract addresses + dev secrets. Production: every secret here MUST
# be sourced from AWS KMS / equivalent — see docs/operations/kms-signer-setup.md.

# ─── Service identity ────────────────────────────────────────────────
ORG_MCP_PORT=3400
ORG_DISPLAY_NAME=Catalyst NoCo Network

# ─── Chain / contracts ───────────────────────────────────────────────
RPC_URL=http://localhost:8545
ORG_CHAIN_ID=31337
DELEGATION_MANAGER_ADDRESS=
AGENT_ACCOUNT_RESOLVER_ADDRESS=
AGENT_RELATIONSHIP_ADDRESS=
POOL_REGISTRY_ADDRESS=
FUND_REGISTRY_ADDRESS=
VOTE_REGISTRY_ADDRESS=
GRANT_PROPOSAL_REGISTRY_ADDRESS=
PLEDGE_REGISTRY_ADDRESS=
MATCH_INITIATION_REGISTRY_ADDRESS=
COMMITMENT_REGISTRY_ADDRESS=
PROPOSAL_REGISTRY_ADDRESS=
CREDENTIAL_REGISTRY_CONTRACT_ADDRESS=

# ─── Storage ─────────────────────────────────────────────────────────
ORG_MCP_DB_PATH=org-mcp.db
ORG_PRIVATE_STORE_PATH=./org-private.db
ORG_ISSUER_BASE_URL=http://localhost:3400

# ─── Inter-service auth (Sprint 4 A.1) ───────────────────────────────
# Shared HMAC secret for the a2a-agent → org-mcp signing hop. HMAC is
# symmetric — both ends hold the same `a2a-to-org` MAC key, so this
# variable is propagated to apps/web/.env (a2a-agent reads it server-side)
# and apps/a2a-agent/.env by `scripts/deploy-local.sh`.
#
# local-aes mode: 32-byte hex (0x-prefixed) random secret.
# aws-kms mode:   set A2A_KMS_BACKEND=aws-kms and
#                 AWS_KMS_MAC_KEY_ID_A2A_TO_ORG to the KMS key ARN.
#                 The legacy env below is ignored in aws-kms mode.
A2A_KMS_BACKEND=local-aes
A2A_INTERSERVICE_HMAC_KEY_ORG=
# AWS_KMS_MAC_KEY_ID_A2A_TO_ORG=arn:aws:kms:us-east-1:111122223333:key/...

# ─── Cross-delegation compat (Sprint 4 A.2) ──────────────────────────
# Dev-only — accept legacy cross-delegations issued before A.2 added
# the DelegateBinding caveat. Ignored in production (NODE_ENV=production).
# Default: unset → reject legacy cross-delegations.
# ACCEPT_LEGACY_CROSS_DELEGATIONS=true
