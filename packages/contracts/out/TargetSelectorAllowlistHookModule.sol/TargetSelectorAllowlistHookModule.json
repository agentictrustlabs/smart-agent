eCheck\",\"outputs\":[{\"internalType\":\"bytes\",\"name\":\"\",\"type\":\"bytes\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"target\",\"type\":\"address\"},{\"internalType\":\"bytes4\",\"name\":\"selector\",\"type\":\"bytes4\"}],\"name\":\"removeAllowed\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{\"isModuleType(uint256)\":{\"details\":\"Callers pass one of the canonical type ids listed above.\"}},\"stateVariables\":{\"_allowed\":{\"details\":\"account => keccak256(target,selector) => allowed\"}},\"title\":\"TargetSelectorAllowlistHookModule\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"addAllowed(address,bytes4)\":{\"notice\":\"Add a new (target, selector) tuple to this account's allowlist.         ONLY callable by the account itself (so the owner can mint         narrower authority via a UserOp or via a delegation chain).\"},\"isModuleType(uint256)\":{\"notice\":\"Returns true iff this module implements the given module type.\"},\"moduleId()\":{\"notice\":\"Stable identifier for this module implementation.         Format is implementation-defined; most deployments use         `{vendor}-{kind}-{version}` e.g. \\\"smart-agent-rate-limit-1\\\".\"}},\"notice\":\"ERC-7579 Hook module (type 4) restricting calls to a runtime-mutable         set of (target, selector) tuples.   Init data shape:     abi.encode(address[] targets, bytes4[] selectors)     Tuples are zipped pairwise \\u2014 index i \\u2194 index i. Lengths must match.   Runtime extension:     `addAllowed(target, selector)` is callable by the account itself (only).     This is the \\\"stateful policy\\\" property \\u2014 the account can mint new     authority for its session WITHOUT redeploying the module or rotating     the owner.   pre/postCheck contract:     preCheck reverts if (target, selector(callData)) is NOT in the     allowlist. Self-calls (target == account) are allowed unconditionally     so owner ops + module management never get gated.     postCheck is a no-op.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/modules/TargetSelectorAllowlistHookModule.sol\":\"TargetSelectorAllowlistHookModule\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":account-abstraction/=lib/account-abstraction/contracts/\",\":erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"],\"viaIR\":true},\"sources\":{\"src/modules/IERC7579Module.sol\":{\"keccak256\":\"0x00140b3e6c498a28e0b4fd468d347d62b81c0f48a43947160c03ffa7cd4600a9\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://0392e2004fe39851d7585306f3deca5baf9abab13ade648f5b62dbe81e605655\",\"dweb:/ipfs/QmdKjmtQR1fqfEnNBJfwjDiKcas8j22XpU65CozUCCpMmb\"]},\"src/modules/TargetSelectorAllowlistHookModule.sol\":{\"keccak256\":\"0xb636460d78882b8c09e613c450dd4f5b6c69264ac84608c6713ef43e72bfe474\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://534b90eb8c384ea1a7fb0efac8de23ba5389d09b581f711f98f554308d384f5e\",\"dweb:/ipfs/Qmaco1z7jK4EFMZ1Kucf48aSvWxiS6pJG4KnRttBsSEcFz\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.28+commit.7893614a"},"language":"Solidity","output":{"abi":[{"inputs":[],"type":"error","name":"InvalidInitData"},{"inputs":[{"internalType":"address","name":"target","type":"address"},{"internalType":"bytes4","name":"selector","type":"bytes4"}],"type":"error","name":"NotAllowed"},{"inputs":[],"type":"error","name":"OnlyAccount"},{"inputs":[{"internalType":"address","name":"account","type":"address","indexed":true},{"internalType":"address","name":"target","type":"address","indexed":true},{"internalType":"bytes4","name":"sel