ing\",\"name\":\"id\",\"type\":\"string\"},{\"internalType\":\"string\",\"name\":\"schemaId\",\"type\":\"string\"},{\"internalType\":\"bytes\",\"name\":\"canonicalJson\",\"type\":\"bytes\"}],\"name\":\"publishCredDef\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"string\",\"name\":\"id\",\"type\":\"string\"},{\"internalType\":\"bytes\",\"name\":\"canonicalJson\",\"type\":\"bytes\"}],\"name\":\"publishSchema\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"string\",\"name\":\"did\",\"type\":\"string\"},{\"internalType\":\"address\",\"name\":\"account\",\"type\":\"address\"}],\"name\":\"registerIssuer\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"string\",\"name\":\"id\",\"type\":\"string\"}],\"name\":\"schemaIssuerOf\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"string\",\"name\":\"id\",\"type\":\"string\"}],\"name\":\"schemaJsonHash\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{},\"title\":\"CredentialRegistry\",\"version\":1},\"userdoc\":{\"events\":{\"CredDefPublished(bytes32,bytes32,address,string,string,bytes,uint64)\":{\"notice\":\"Emitted when a credential definition is published.\"},\"RevStatusUpdated(bytes32,uint64,bytes32,address,bytes,uint64)\":{\"notice\":\"Reserved for future revocation-status updates. Not yet emitted.\"},\"SchemaPublished(bytes32,bytes32,address,string,bytes,uint64)\":{\"notice\":\"Emitted when a schema is published. `canonicalJson` is the full AnonCreds schema payload (minified, key-sorted). Verifiers recover it from event data and check keccak256(canonicalJson) == jsonHash.\"}},\"kind\":\"user\",\"methods\":{\"publishCredDef(string,string,bytes)\":{\"notice\":\"Publish a credential definition bound to an already-published schema. Canonical-JSON lives in event data.\"},\"publishSchema(string,bytes)\":{\"notice\":\"Publish a schema. The canonical-JSON bytes are emitted in event data; only the keccak hashes are stored on-chain. Caller must be a registered issuer. One publish per id.\"},\"registerIssuer(string,address)\":{\"notice\":\"Register a did:ethr issuer. The caller MUST be the EOA in the DID.\"},\"schemaJsonHash(string)\":{\"notice\":\"Sentinel view \\u2014 verifier checks keccak(canonicalJson) against the hash stored on-chain. Canonical bytes are fetched from event data.\"}},\"notice\":\"On-chain Data Layer Registry for AnonCreds (cheqd-style).   Schemas and credential definitions are PUBLISHED on-chain in full: the   canonical-JSON bytes land in event data (cheap LOG cost, not SSTORE).   A verifier with only an RPC URL and this contract address can resolve   and verify every credential it sees \\u2014 the issuer is NOT in the   verification path.   Identity. An issuer registers its did:ethr by proving control of the   EOA. The on-chain msg.sender of every publish* call IS the provenance   of the published record \\u2014 no off-chain signature required.   Storage model. We keep two sentinels on-chain per id:     - the indexed jsonHash (so log filters are cheap), and     - a \\\"published\\\" flag (so re-publish is rejected).   The canonical JSON itself lives in the event's non-indexed data, which   a full-archive RPC node returns via eth_getLogs.   Revocation. Reserved as RevStatusUpdated below (not implemented \\u2014 the   credentials we mint in this build are non-revocable).\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/CredentialRegistry.sol\":\"CredentialRegistry\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":account-abstraction/=lib/account-abstraction/contracts/\",\":erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"],\"viaIR\":true},\"sources\":{\"src/CredentialRegistry.sol\":{\"keccak256\":\"0x7c92e207ad075a2238843851847b325781778e17f9d0c1656d3d57b0b1534519\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://734af25cf8c5d510e6c34b69b82161d911d935d0af979bd2853fe48ab6da4729\",\"dweb:/ipfs/QmU9h6i9sP2Vs2jx59qhvuAhUKNV3LhNXD9XCTth6Z6zYi\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.28+commit.7893614a"},"language":"Solidity","output":{"abi":[{"inputs":[],"type":"error","name":"CredDefAlreadyPublished"},{"inputs":[],"type":"error","name":"EmptyId"},{"inputs":[],"type":"error","name":"EmptyJson"},{"inputs":[],"type":"error","name":"IssuerAlreadyRegistered"},{"inputs":[],"type":"error","name":"NotIssuerAccount"},{"inputs":[],"type":"error","name":"SchemaAlreadyPublished"},{"inputs":[],"type":"error","name":"UnknownIssuer"},{"inputs":[],"type":"error","name":"UnknownSchema"},{"inputs":[{"internalType":"bytes32","name":"credDefIdKey","type":"bytes32","indexed":true},{"internalType":"bytes32","name":"jsonHash","type":"bytes32","indexed":true},{"internalType":"address","name":"issuer","type":"address","indexed":true},{"internalType":"string","name":"id","type":"string","indexed":false},{"internalType":"string","name":"schemaId","type":"string","indexed":false},{"internalType":"bytes","name":"canonicalJson","type":"bytes","indexed":false},{"internalType":"uint64","name":"at","type":"uint64","indexed":false}],"type":"event","name":"CredDefPublished","anonymous":false},{"inputs":[{"internalType":"string","name":"did","type":"string","indexed":false},{"internalType":"address","name":"account","type":"address","indexed":true},{"internalType":"uint64","name":"at","t