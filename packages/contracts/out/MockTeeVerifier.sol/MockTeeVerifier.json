e","verifyNitro(address,bytes32,bytes32,bytes32,bytes)":"781d3bfa","verifyTdx(address,bytes32,bytes32,bytes32,bytes)":"6dfab94e"},"rawMetadata":"{\"compiler\":{\"version\":\"0.8.28+commit.7893614a\"},\"language\":\"Solidity\",\"output\":{\"abi\":[{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"address\",\"name\":\"agent\",\"type\":\"address\"},{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"codeMeasurement\",\"type\":\"bytes32\"}],\"name\":\"AttestationRevoked\",\"type\":\"event\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"address\",\"name\":\"agent\",\"type\":\"address\"},{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"codeMeasurement\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"bytes32\",\"name\":\"teeArch\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"uint256\",\"name\":\"verifiedAt\",\"type\":\"uint256\"}],\"name\":\"AttestationVerified\",\"type\":\"event\"},{\"inputs\":[],\"name\":\"TEE_NITRO\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"TEE_SEV\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"TEE_SGX\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"TEE_TDX\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"attestationCount\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"agent\",\"type\":\"address\"}],\"name\":\"getAgentMeasurements\",\"outputs\":[{\"internalType\":\"bytes32[]\",\"name\":\"\",\"type\":\"bytes32[]\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"codeMeasurement\",\"type\":\"bytes32\"}],\"name\":\"getAttestation\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"agent\",\"type\":\"address\"},{\"internalType\":\"bytes32\",\"name\":\"teeArch\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"pcr0\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"pcr1\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"pcr2\",\"type\":\"bytes32\"},{\"internalType\":\"bytes\",\"name\":\"publicKey\",\"type\":\"bytes\"},{\"internalType\":\"uint256\",\"name\":\"verifiedAt\",\"type\":\"uint256\"},{\"internalType\":\"bool\",\"name\":\"valid\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"codeMeasurement\",\"type\":\"bytes32\"}],\"name\":\"isValid\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"codeMeasurement\",\"type\":\"bytes32\"}],\"name\":\"revoke\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"agent\",\"type\":\"address\"},{\"internalType\":\"bytes32\",\"name\":\"teeArch\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"measurement0\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"measurement1\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"measurement2\",\"type\":\"bytes32\"},{\"internalType\":\"bytes\",\"name\":\"publicKey\",\"type\":\"bytes\"}],\"name\":\"verify\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"codeMeasurement\",\"type\":\"bytes32\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"agent\",\"type\":\"address\"},{\"internalType\":\"bytes32\",\"name\":\"pcr0\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"pcr1\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"pcr2\",\"type\":\"bytes32\"},{\"internalType\":\"bytes\",\"name\":\"publicKey\",\"type\":\"bytes\"}],\"name\":\"verifyNitro\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"codeMeasurement\",\"type\":\"bytes32\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"agent\",\"type\":\"address\"},{\"internalType\":\"bytes32\",\"name\":\"mrtd\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"rtmr0\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"rtmr1\",\"type\":\"bytes32\"},{\"internalType\":\"bytes\",\"name\":\"publicKey\",\"type\":\"bytes\"}],\"name\":\"verifyTdx\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"codeMeasurement\",\"type\":\"bytes32\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{\"verifyNitro(address,bytes32,bytes32,bytes32,bytes)\":{\"params\":{\"agent\":\"The agent smart account this attestation is for.\",\"pcr0\":\"PCR0: Enclave image measurement.\",\"pcr1\":\"PCR1: Linux kernel and bootstrap measurement.\",\"pcr2\":\"PCR2: Application code measurement.\",\"publicKey\":\"The public key bound to this TEE instance.\"},\"returns\":{\"codeMeasurement\":\"The computed keccak256(pcr0 || pcr1 || pcr2). In production, this would:   1. Parse the COSE_Sign1 attestation document   2. Verify the X.509 certificate chain back to AWS root   3. Verify the ECDSA-384 signature   4. Extract PCR0, PCR1, PCR2 from the attested document   5. Return the measurement hash\"}},\"verifyTdx(address,bytes32,bytes32,bytes32,bytes)\":{\"params\":{\"agent\":\"The agent smart account.\",\"mrtd\":\"Measurement of the Trust Domain.\",\"publicKey\":\"The public key bound to this TEE instance.\",\"rtmr0\":\"Runtime measurement register 0 (firmware).\",\"rtmr1\":\"Runtime measurement register 1 (OS/kernel).\"},\"returns\":{\"codeMeasurement\":\"The computed keccak256(mrtd || rtmr0 || rtmr1). In production, this would call Automata's DCAP verifier to parse and verify a raw Intel TDX quote against cached Intel collaterals.\"}}},\"title\":\"MockTeeVerifier\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"revoke(bytes32)\":{\"notice\":\"Revoke an attestation (e.g., when agent code is updated).\"},\"verify(address,bytes32,bytes32,bytes32,bytes32,bytes)\":{\"notice\":\"Generic verify: accepts pre-computed measurements.         Useful for testing or when the caller has already parsed the quote.\"},\"verifyNitro(address,bytes32,bytes32,bytes32,bytes)\":{\"notice\":\"Simulate verifying an AWS Nitro attestation.\"},\"verifyTdx(address,bytes32,bytes32,bytes32,bytes)\":{\"notice\":\"Simulate verifying an Intel TDX attestation.\"}},\"notice\":\"Development TEE verifier that simulates attestation verification. In production, this would be replaced by:   - Automata DCAP Verifier (Intel TDX/SGX) \\u2014 parses raw DCAP quotes on-chain   - Base Nitro Validator (AWS Nitro) \\u2014 verifies COSE_Sign1 + X.509 chain   - Phala dstack Verifier \\u2014 off-chain TEE-based verification with on-chain signature This mock follows the same IVerifier interface pattern proposed in the ERC-8004 TEE Registry discussion: accept raw attestation bytes, return a code measurement (bytes32). The mock computes measurements from input data rather than verifying real hardware attestations, enabling end-to-end testing of the full TEE validation flow without actual TEE hardware.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/MockTeeVerifier.sol\":\"MockTeeVerifier\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":account-abstraction/=lib/account-abstraction/contracts/\