\",\"name\":\"classId\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"subjectId\",\"type\":\"bytes32\"},{\"internalType\":\"address\",\"name\":\"asserter\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"validFrom\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"validUntil\",\"type\":\"uint256\"},{\"internalType\":\"bool\",\"name\":\"revoked\",\"type\":\"bool\"},{\"internalType\":\"string\",\"name\":\"payloadURI\",\"type\":\"string\"}],\"internalType\":\"struct ClassAssertion.AssertionRecord\",\"name\":\"\",\"type\":\"tuple\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"asserter\",\"type\":\"address\"}],\"name\":\"getAssertionsByAsserter\",\"outputs\":[{\"internalType\":\"uint256[]\",\"name\":\"\",\"type\":\"uint256[]\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"classId\",\"type\":\"bytes32\"}],\"name\":\"getAssertionsByClass\",\"outputs\":[{\"internalType\":\"uint256[]\",\"name\":\"\",\"type\":\"uint256[]\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"subjectId\",\"type\":\"bytes32\"}],\"name\":\"getAssertionsBySubject\",\"outputs\":[{\"internalType\":\"uint256[]\",\"name\":\"\",\"type\":\"uint256[]\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"assertionId\",\"type\":\"uint256\"}],\"name\":\"isAssertionCurrentlyValid\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"assertionId\",\"type\":\"uint256\"}],\"name\":\"revokeAssertion\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{\"assertClass(bytes32,bytes32,uint256,uint256,string)\":{\"params\":{\"classId\":\"keccak256 of the assertion class IRI (e.g., sa:MatchInitiationAssertion).\",\"payloadURI\":\"Off-chain content reference. Indexed by the GraphDB sync.\",\"subjectId\":\"keccak256 of the subject IRI (the artifact's IRI).\",\"validFrom\":\"Unix seconds; 0 \\u2192 block.timestamp.\",\"validUntil\":\"Unix seconds; 0 \\u2192 never expires.\"},\"returns\":{\"assertionId\":\"The newly minted id.\"}}},\"title\":\"ClassAssertion\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"assertClass(bytes32,bytes32,uint256,uint256,string)\":{\"notice\":\"Anchor a class-tagged assertion on chain.\"}},\"notice\":\"Generic class-tagged assertion log for off-chain artifacts         (intent-marketplace and beyond). Companion to AgentAssertion (which is edge-focused). ClassAssertion anchors any class-tagged event whose subject is not necessarily an agent-relationship edge:   sa:MatchInitiationAssertion        \\u2014 links two intents   sa:PledgeAssertion                 \\u2014 links donor + pool (with amount)   sa:PoolPledgedTotalAssertion       \\u2014 aggregate on a pool, donor-less   sa:RoundOpenedAssertion            \\u2014 round lifecycle event   sa:RoundClosedAssertion            \\u2014 round lifecycle event Each assertion carries:   classId    \\u2014 keccak256 of the class IRI (off-chain pre-computed)   subjectId  \\u2014 keccak256 of the subject IRI (the artifact's own IRI;                for relationships, callers compose subject + object IRIs)   payloadURI \\u2014 off-chain content reference (JSON / IPFS / data: URI);                the on-chain \\u2192 GraphDB sync ingests this. Privacy: This contract anchors PUBLIC-tier artifacts only. Callers MUST NOT call it for private-tier artifacts (e.g., sa:GrantProposal in v1, anonymous PoolPledges, MatchInitiations referencing a private intent). SHACL shapes in docs/ontology/tbox/shacl/visibility.ttl document the privacy invariants; enforcement is in the calling MCP. No relationship-edge dependency \\u2014 a ClassAssertion can exist for any subject, including artifacts that have no representation in AgentRelationship (intents, pools, rounds, pledges, proposals).\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/ClassAssertion.sol\":\"ClassAssertion\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":account-abstraction/=lib/account-abstraction/contracts/\",\":erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"],\"viaIR\":true},\"sources\":{\"src/ClassAssertion.sol\":{\"keccak256\":\"0x40745e1d9684de63d6231bc6e94ea8fb25814d92d54019c3e962a3f64c8ab437\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://8a2752fbab08462b38ae6e7806e69e9aa4601d71087dcf92d2503b0d191c6c8a\",\"dweb:/ipfs/QmdrVGpb6BmzAg4u3iSieB16TteiAd5bjET8G8jDmqARaA\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.28+commit.7893614a"},"language":"Solidity","output":{"abi":[{"inputs":[],"type":"error","name":"AlreadyRevoked"},{"inputs":[],"type":"error","name":"AssertionNotFound"},{"inputs":[],"type":"error","name":"InvalidAssertion"},{"inputs":[],"type":"error","name":"NotAuthorized"},{"inputs":[{"internalType":"uint256","name":"assertionId","type":"uint256","indexed":true},{"internalType":"bytes32","name":"classId","type":"bytes32","indexed":true},{"internalType":"bytes32","name":"subjectId","type":"bytes32","indexed":true},{"internalType":"address","name":"asserter","type":"address","indexed":false},{"internalType":"uint256","name":"validFrom","type":"uint256","indexed":false},{"internalType":"uint256","name":"validUntil","type":"uint256","indexed":false},{"internalType":"string","name":"payloadURI","type":"string","indexed":false}],"type":"event","name":"ClassAssertionMade","