pe\":\"address\",\"name\":\"pool\",\"type\":\"address\"}],\"name\":\"getEligibleStewards\",\"outputs\":[{\"internalType\":\"address[]\",\"name\":\"active\",\"type\":\"address[]\"},{\"internalType\":\"uint8\",\"name\":\"t\",\"type\":\"uint8\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"pool\",\"type\":\"address\"},{\"internalType\":\"address\",\"name\":\"steward\",\"type\":\"address\"}],\"name\":\"isEligible\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"pool\",\"type\":\"address\"},{\"internalType\":\"address\",\"name\":\"steward\",\"type\":\"address\"},{\"internalType\":\"bool\",\"name\":\"eligible\",\"type\":\"bool\"}],\"name\":\"setSteward\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"pool\",\"type\":\"address\"},{\"internalType\":\"uint8\",\"name\":\"newThreshold\",\"type\":\"uint8\"}],\"name\":\"setThreshold\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"name\":\"threshold\",\"outputs\":[{\"internalType\":\"uint8\",\"name\":\"\",\"type\":\"uint8\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"details\":\"The motivation (per output/dao-pool-round-best-practices.md \\u00a7 3 Q3      and output/safe-architecture-comparison.md \\u00a7 3 Q6) is to avoid      re-minting STEWARDSHIP_DELEGATION on every steward rotation.      Instead, `StewardEligibilityEnforcer` reads `isEligible` at      sig-verification time; flipping a steward's eligibility is a      single SSTORE, and revocation cascades automatically.      Auth: only the Pool itself (msg.sender == pool) can update its      eligibility set. Same rationale as MandateRegistry \\u2014 a steward      mutation must come through a redeemed delegation.      Mirror class assertion: `sa:StewardSetUpdatedAssertion`.\",\"kind\":\"dev\",\"methods\":{},\"title\":\"StewardEligibilityRegistry\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"eligibility(address,address)\":{\"notice\":\"pool => steward => is eligible\"},\"getEligibleStewards(address)\":{\"notice\":\"Returns the (eligibility-filtered) steward list for a pool.         Off-chain callers prefer this over reading _stewards directly         because `_stewards` may carry de-flagged entries.\"},\"isEligible(address,address)\":{\"notice\":\"Cheap eligibility lookup used by StewardEligibilityEnforcer.\"},\"setSteward(address,address,bool)\":{\"notice\":\"Flip a steward's eligibility. Adding a previously-unknown         steward also appends them to the ordered list; removing         leaves them in the list with `eligibility[steward] = false`         (cheap; readers must filter on `isEligible`).\"},\"threshold(address)\":{\"notice\":\"pool => threshold (N-of-M)\"}},\"notice\":\"Per-pool current steward set + per-steward eligibility flag.         Borrowed from Hats Protocol's `IHatsEligibility` shape, adapted         to our pool model.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/StewardEligibilityRegistry.sol\":\"StewardEligibilityRegistry\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":account-abstraction/=lib/account-abstraction/contracts/\",\":erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"],\"viaIR\":true},\"sources\":{\"src/StewardEligibilityRegistry.sol\":{\"keccak256\":\"0x2d4a155f3ac6d27e5cd6cc5473374df600455017aa37e9023f85baf3a5fad91a\",\"li