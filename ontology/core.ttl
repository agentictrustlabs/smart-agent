@prefix atl: <https://agentictrust.io/ontology/core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# ─────────────────────────────────────────────────────────────────────
# Agentic Trust Labs — Core Ontology
#
# Defines classes and properties for ERC-4337 agent smart accounts
# in the Smart Agent trust fabric. Used with SHACL shapes for
# validation and JSON-LD context for serialization.
# ─────────────────────────────────────────────────────────────────────

atl: a owl:Ontology ;
    rdfs:label "Agentic Trust Labs Core Ontology" ;
    rdfs:comment "Semantic vocabulary for ERC-4337 agent smart accounts, trust relationships, and delegation authority." ;
    dcterms:creator "Agentic Trust Labs" ;
    owl:versionInfo "1.0.0" .

# ═══════════════════════════════════════════════════════════════════════
# Classes
# ═══════════════════════════════════════════════════════════════════════

atl:AgentAccount a rdfs:Class ;
    rdfs:label "Agent Account" ;
    rdfs:comment "An ERC-4337 smart account serving as an agent's on-chain identity anchor. The account address is the canonical subject (did:ethr:<chainId>:<address>)." .

atl:PersonAgent a rdfs:Class ;
    rdfs:subClassOf atl:AgentAccount ;
    rdfs:label "Person Agent" ;
    rdfs:comment "An agent account controlled by an individual human. Represents the person's on-chain identity for interacting with the trust fabric." .

atl:OrganizationAgent a rdfs:Class ;
    rdfs:subClassOf atl:AgentAccount ;
    rdfs:label "Organization Agent" ;
    rdfs:comment "An agent account representing an organization, DAO, or legal entity. May have multi-sig governance and sub-agents." .

atl:AIAgent a rdfs:Class ;
    rdfs:subClassOf atl:AgentAccount ;
    rdfs:label "AI Agent" ;
    rdfs:comment "An autonomous or semi-autonomous AI agent operating under programmatic delegation. Typically operated by an organization and may run in a TEE." .

# ─── AI Agent Subclasses ─────────────────────────────────────────────

atl:DiscoveryAgent a rdfs:Class ;
    rdfs:subClassOf atl:AIAgent ;
    rdfs:label "Discovery Agent" ;
    rdfs:comment "Discovers and evaluates other agents in the trust fabric." .

atl:ValidatorAgent a rdfs:Class ;
    rdfs:subClassOf atl:AIAgent ;
    rdfs:label "Validator Agent" ;
    rdfs:comment "Validates agent activities, attestations, or compliance." .

atl:ExecutorAgent a rdfs:Class ;
    rdfs:subClassOf atl:AIAgent ;
    rdfs:label "Executor Agent" ;
    rdfs:comment "Executes delegated tasks on behalf of other agents." .

atl:AssistantAgent a rdfs:Class ;
    rdfs:subClassOf atl:AIAgent ;
    rdfs:label "Assistant Agent" ;
    rdfs:comment "Provides assistance and information to human users." .

atl:OracleAgent a rdfs:Class ;
    rdfs:subClassOf atl:AIAgent ;
    rdfs:label "Oracle Agent" ;
    rdfs:comment "Provides external data feeds and attestations." .

# ─── Trust Model Classes ─────────────────────────────────────────────

atl:TrustModel a rdfs:Class ;
    rdfs:label "Trust Model" ;
    rdfs:comment "A mechanism through which an agent establishes trust." .

atl:ReputationTrust a rdfs:Class ;
    rdfs:subClassOf atl:TrustModel ;
    rdfs:label "Reputation Trust" .

atl:CryptoEconomicTrust a rdfs:Class ;
    rdfs:subClassOf atl:TrustModel ;
    rdfs:label "Crypto-Economic Trust" .

atl:TEEAttestation a rdfs:Class ;
    rdfs:subClassOf atl:TrustModel ;
    rdfs:label "TEE Attestation Trust" .

# ═══════════════════════════════════════════════════════════════════════
# Properties
# ═══════════════════════════════════════════════════════════════════════

# ─── Core Identity ───────────────────────────────────────────────────

atl:accountAddress a rdf:Property ;
    rdfs:label "Account Address" ;
    rdfs:comment "The ERC-4337 smart account address (0x...)." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

atl:displayName a rdf:Property ;
    rdfs:label "Display Name" ;
    rdfs:comment "Human-readable name for the agent." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

atl:description a rdf:Property ;
    rdfs:label "Description" ;
    rdfs:comment "Description of the agent's purpose and capabilities." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

atl:isActive a rdf:Property ;
    rdfs:label "Is Active" ;
    rdfs:comment "Whether the agent is currently active." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:boolean .

atl:version a rdf:Property ;
    rdfs:label "Version" ;
    rdfs:comment "Agent implementation version." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

# ─── Classification ──────────────────────────────────────────────────

atl:agentType a rdf:Property ;
    rdfs:label "Agent Type" ;
    rdfs:comment "The primary type classification (PersonAgent, OrganizationAgent, AIAgent)." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range rdfs:Class .

atl:aiAgentClass a rdf:Property ;
    rdfs:label "AI Agent Class" ;
    rdfs:comment "Subclass for AI agents (DiscoveryAgent, ValidatorAgent, etc.)." ;
    rdfs:domain atl:AIAgent ;
    rdfs:range rdfs:Class .

# ─── Service Endpoints ───────────────────────────────────────────────

atl:hasA2AEndpoint a rdf:Property ;
    rdfs:label "A2A Endpoint" ;
    rdfs:comment "Agent-to-Agent communication endpoint URI." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:anyURI .

atl:hasMCPServer a rdf:Property ;
    rdfs:label "MCP Server" ;
    rdfs:comment "Model Context Protocol server endpoint URI." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:anyURI .

atl:hasServiceEndpoint a rdf:Property ;
    rdfs:label "Service Endpoint" ;
    rdfs:comment "Generic service endpoint URI." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:anyURI .

# ─── Trust & Capabilities ────────────────────────────────────────────

atl:supportedTrustModel a rdf:Property ;
    rdfs:label "Supported Trust Model" ;
    rdfs:comment "Trust models this agent supports (reputation, crypto-economic, tee-attestation)." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

atl:hasCapability a rdf:Property ;
    rdfs:label "Capability" ;
    rdfs:comment "A capability or skill this agent offers." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

# ─── Relationships ───────────────────────────────────────────────────

atl:hasController a rdf:Property ;
    rdfs:label "Controller" ;
    rdfs:comment "EOA wallet address that controls this agent (owner in the multi-sig set)." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

atl:operatedBy a rdf:Property ;
    rdfs:label "Operated By" ;
    rdfs:comment "Organization agent that operates this AI agent." ;
    rdfs:domain atl:AIAgent ;
    rdfs:range atl:OrganizationAgent .

# ─── Relationship Taxonomy ───────────────────────────────────────────

atl:RelationshipType a rdfs:Class ;
    rdfs:label "Relationship Type" ;
    rdfs:comment "Semantic class for an edge type used in AgentRelationship." .

atl:RelationshipRole a rdfs:Class ;
    rdfs:label "Relationship Role" ;
    rdfs:comment "Semantic class for a role played within a relationship edge." .

atl:InstitutionalRelationship a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipType ;
    rdfs:label "Institutional Relationship" .

atl:NetworkRelationship a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipType ;
    rdfs:label "Network Relationship" .

atl:AssuranceRelationship a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipType ;
    rdfs:label "Assurance Relationship" .

atl:ExecutionRelationship a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipType ;
    rdfs:label "Execution Relationship" .

atl:CapitalRelationship a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipType ;
    rdfs:label "Capital Relationship" .

atl:InfrastructureRelationship a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipType ;
    rdfs:label "Infrastructure Relationship" .

atl:OrganizationGovernanceRelationship a rdfs:Class ;
    rdfs:subClassOf atl:InstitutionalRelationship ;
    rdfs:label "Organization Governance Relationship" .

atl:OrganizationMembershipRelationship a rdfs:Class ;
    rdfs:subClassOf atl:InstitutionalRelationship ;
    rdfs:label "Organization Membership Relationship" .

atl:AllianceRelationship a rdfs:Class ;
    rdfs:subClassOf atl:NetworkRelationship ;
    rdfs:label "Alliance Relationship" .

atl:GenerationalLineageRelationship a rdfs:Class ;
    rdfs:subClassOf atl:NetworkRelationship ;
    rdfs:label "Generational Lineage Relationship" ;
    rdfs:comment "Generational multiplication lineage between groups — the upstream group planted or catalyzed the downstream group." .

atl:ValidationTrustRelationship a rdfs:Class ;
    rdfs:subClassOf atl:AssuranceRelationship ;
    rdfs:label "Validation Trust Relationship" .

atl:InsuranceCoverageRelationship a rdfs:Class ;
    rdfs:subClassOf atl:AssuranceRelationship ;
    rdfs:label "Insurance Coverage Relationship" .

atl:ComplianceRelationship a rdfs:Class ;
    rdfs:subClassOf atl:AssuranceRelationship ;
    rdfs:label "Compliance Relationship" .

atl:EconomicSecurityRelationship a rdfs:Class ;
    rdfs:subClassOf atl:CapitalRelationship ;
    rdfs:label "Economic Security Relationship" .

atl:ServiceAgreementRelationship a rdfs:Class ;
    rdfs:subClassOf atl:ExecutionRelationship ;
    rdfs:label "Service Agreement Relationship" .

atl:DelegationAuthorityRelationship a rdfs:Class ;
    rdfs:subClassOf atl:ExecutionRelationship ;
    rdfs:label "Delegation Authority Relationship" .

atl:RuntimeAttestationRelationship a rdfs:Class ;
    rdfs:subClassOf atl:InfrastructureRelationship ;
    rdfs:label "Runtime Attestation Relationship" .

atl:BuildProvenanceRelationship a rdfs:Class ;
    rdfs:subClassOf atl:InfrastructureRelationship ;
    rdfs:label "Build Provenance Relationship" .

atl:OrganizationalControlRelationship a rdfs:Class ;
    rdfs:subClassOf atl:ExecutionRelationship ;
    rdfs:label "Organizational Control Relationship" .

atl:ActivityValidationRelationship a rdfs:Class ;
    rdfs:subClassOf atl:AssuranceRelationship ;
    rdfs:label "Activity Validation Relationship" .

atl:ReviewRelationship a rdfs:Class ;
    rdfs:subClassOf atl:AssuranceRelationship ;
    rdfs:label "Review Relationship" .

atl:HasMemberRelationship a rdfs:Class ;
    rdfs:subClassOf atl:NetworkRelationship ;
    rdfs:label "Has Member Relationship" .

atl:GovernanceRole a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipRole ;
    rdfs:label "Governance Role" .

atl:MembershipRole a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipRole ;
    rdfs:label "Membership Role" .

atl:AssuranceRole a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipRole ;
    rdfs:label "Assurance Role" .

atl:ServiceRole a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipRole ;
    rdfs:label "Service Role" .

atl:EconomicRole a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipRole ;
    rdfs:label "Economic Role" .

atl:AllianceRole a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipRole ;
    rdfs:label "Alliance Role" .

atl:ExecutionRole a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipRole ;
    rdfs:label "Execution Role" .

atl:InfrastructureRole a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipRole ;
    rdfs:label "Infrastructure Role" .

atl:OwnerRole a rdfs:Class ;
    rdfs:subClassOf atl:GovernanceRole ;
    rdfs:label "Owner Role" .

atl:BoardMemberRole a rdfs:Class ;
    rdfs:subClassOf atl:GovernanceRole ;
    rdfs:label "Board Member Role" .

atl:ChiefExecutiveRole a rdfs:Class ;
    rdfs:subClassOf atl:GovernanceRole ;
    rdfs:label "Chief Executive Role" .

atl:TreasurerRole a rdfs:Class ;
    rdfs:subClassOf atl:GovernanceRole ;
    rdfs:label "Treasurer Role" .

atl:AuthorizedSignerRole a rdfs:Class ;
    rdfs:subClassOf atl:GovernanceRole ;
    rdfs:label "Authorized Signer Role" .

atl:AdvisorRole a rdfs:Class ;
    rdfs:subClassOf atl:RelationshipRole ;
    rdfs:label "Advisor Role" .

atl:AdministratorRole a rdfs:Class ;
    rdfs:subClassOf atl:MembershipRole ;
    rdfs:label "Administrator Role" .

atl:MemberRole a rdfs:Class ;
    rdfs:subClassOf atl:MembershipRole ;
    rdfs:label "Member Role" .

atl:OperatorRole a rdfs:Class ;
    rdfs:subClassOf atl:MembershipRole ;
    rdfs:label "Operator Role" .

atl:AuditorRole a rdfs:Class ;
    rdfs:subClassOf atl:AssuranceRole ;
    rdfs:label "Auditor Role" .

atl:ValidatorRole a rdfs:Class ;
    rdfs:subClassOf atl:AssuranceRole ;
    rdfs:label "Validator Role" .

atl:StrategicPartnerRole a rdfs:Class ;
    rdfs:subClassOf atl:AllianceRole ;
    rdfs:label "Strategic Partner Role" .

atl:UpstreamRole a rdfs:Class ;
    rdfs:subClassOf atl:NetworkRole ;
    rdfs:label "Upstream Role" ;
    rdfs:comment "The originating or parent group in a generational lineage." .

atl:DownstreamRole a rdfs:Class ;
    rdfs:subClassOf atl:NetworkRole ;
    rdfs:label "Downstream Role" ;
    rdfs:comment "The spawned or daughter group in a generational lineage." .

atl:ServiceProviderRole a rdfs:Class ;
    rdfs:subClassOf atl:ServiceRole ;
    rdfs:label "Service Provider Role" .

atl:StakerRole a rdfs:Class ;
    rdfs:subClassOf atl:EconomicRole ;
    rdfs:label "Staker Role" .

atl:ReviewerRole a rdfs:Class ;
    rdfs:subClassOf atl:AssuranceRole ;
    rdfs:label "Reviewer Role" .

atl:ReviewedAgentRole a rdfs:Class ;
    rdfs:subClassOf atl:AssuranceRole ;
    rdfs:label "Reviewed Agent Role" .

atl:OperatedAgentRole a rdfs:Class ;
    rdfs:subClassOf atl:ExecutionRole ;
    rdfs:label "Operated Agent Role" .

atl:appliesToRelationshipType a rdf:Property ;
    rdfs:label "Applies To Relationship Type" ;
    rdfs:comment "Associates a role or policy term with a relationship type." ;
    rdfs:range atl:RelationshipType .

atl:delegationPolicyKey a rdf:Property ;
    rdfs:label "Delegation Policy Key" ;
    rdfs:comment "Off-chain policy key used to resolve executable delegation caveats." ;
    rdfs:range xsd:string .

atl:delegationTemplateName a rdf:Property ;
    rdfs:label "Delegation Template Name" ;
    rdfs:comment "Human-readable template name associated with a relationship role." ;
    rdfs:range xsd:string .

atl:hubLabel_generic a rdf:Property ;
    rdfs:label "Hub Label (Generic)" ;
    rdfs:range xsd:string .

atl:hubLabel_catalyst a rdf:Property ;
    rdfs:label "Hub Label (Catalyst)" ;
    rdfs:range xsd:string .

atl:hubLabel_globalChurch a rdf:Property ;
    rdfs:label "Hub Label (Global Church)" ;
    rdfs:range xsd:string .

atl:hubLabel_cil a rdf:Property ;
    rdfs:label "Hub Label (CIL)" ;
    rdfs:range xsd:string .

# ─── Metadata ────────────────────────────────────────────────────────

atl:metadataURI a rdf:Property ;
    rdfs:label "Metadata URI" ;
    rdfs:comment "URI to the canonical JSON-LD metadata document (typically on IPFS)." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:anyURI .

atl:schemaURI a rdf:Property ;
    rdfs:label "Schema URI" ;
    rdfs:comment "URI to the SHACL shape that validates this agent's metadata." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:anyURI .

# ─── ERC-4337 Technical ──────────────────────────────────────────────

atl:entryPoint a rdf:Property ;
    rdfs:label "Entry Point" ;
    rdfs:comment "ERC-4337 EntryPoint contract address." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

atl:delegationManager a rdf:Property ;
    rdfs:label "Delegation Manager" ;
    rdfs:comment "ERC-7710 DelegationManager contract address authorized to execute on behalf of this agent." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

# ─── Geospatial (GeoSPARQL-aligned) ────────────────────────────────
# Lightweight on-chain spatial metadata. Maps to geo:asWKT "POINT(lon lat)"
# via the GeoSPARQL 1.1 profile. CRS defaults to EPSG:4326 (WGS84).

atl:latitude a rdf:Property ;
    rdfs:label "Latitude" ;
    rdfs:comment "WGS84 latitude coordinate as decimal string (-90 to 90). Maps to geo:asWKT point Y value." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

atl:longitude a rdf:Property ;
    rdfs:label "Longitude" ;
    rdfs:comment "WGS84 longitude coordinate as decimal string (-180 to 180). Maps to geo:asWKT point X value." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

atl:spatialCRS a rdf:Property ;
    rdfs:label "Spatial CRS" ;
    rdfs:comment "Coordinate Reference System identifier (e.g., EPSG:4326). Defaults to WGS84." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .

atl:spatialType a rdf:Property ;
    rdfs:label "Spatial Type" ;
    rdfs:comment "Geometry type: Point, Polygon, LineString, etc. Aligns with GeoSPARQL geometry types." ;
    rdfs:domain atl:AgentAccount ;
    rdfs:range xsd:string .
